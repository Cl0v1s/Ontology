      ],
      "definition": "The presence of redundant or conflicting documentation pages covering the same topic, leading to confusion and maintenance overhead.",
      "domain": "knowledge management"
    },
    {
      "@id": "ko:concept/archive-teamspace",
      "@type": "ko:Concept",
      "prefLabel": "Archive Teamspace",
      "definition": "A dedicated Notion teamspace used to store deprecated or outdated documentation rather than deleting it outright.",
      "domain": "knowledge management"
    },
    {
      "@id": "ko:concept/stale-hierarchies",
      "@type": "ko:Concept",
      "prefLabel": "Stale Hierarchies",
      "definition": "Outdated organizational structures in documentation systems that no longer reflect the current state of the organization or product.",
      "domain": "knowledge management"
    },
    {
      "@id": "ko:concept/verified-documentation",
      "@type": "ko:Concept",
      "prefLabel": "Verified Documentation",
      "definition": "Documentation that has been explicitly reviewed and confirmed to be accurate and up-to-date.",
