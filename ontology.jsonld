    {
      "@id": "ko:concept/collapsologie",
      "@type": "ko:Concept",
      "prefLabel": "Collapsology",
      "altLabel": [
        "collapsologie",
        "science de l'effondrement"
      ],
      "definition": "Exercice transdisciplinaire visant \u00e0 l\u2019\u00e9tude de l\u2019effondrement de la soci\u00e9t\u00e9 thermo-industrielle et de ce qui pourrait lui succ\u00e9der.",
      "domain": "ecology, sociology"
    },
    {
      "@id": "ko:concept/transdisciplinarite",
      "@type": "ko:Concept",
      "prefLabel": "Transdisciplinarity",
      "altLabel": [
        "transdisciplinarit\u00e9"
      ],
      "definition": "Approche qui d\u00e9passe les fronti\u00e8res des disciplines sp\u00e9cialis\u00e9es pour construire de nouvelles connaissances.",
      "domain": "science"
    },
    {
      "@id": "ko:concept/multidisciplinarite",
      "@type": "ko:Concept",
      "prefLabel": "Multidisciplinary Approach",
      "altLabel": [
        "multidisciplinarit\u00e9"
      ],
      "definition": "Approche centr\u00e9e sur plusieurs disciplines sans les int\u00e9grer pour construire de nouvelles connaissances.",
      "domain": "science"
    },
    {
      "@id": "ko:concept/science",
      "@type": "ko:Concept",
      "prefLabel": "Science",
      "altLabel": [
        "science"
      ],
      "definition": "Ensemble de connaissances valides produites par des m\u00e9thodes rigoureuses, valid\u00e9es par les pairs et soumises au consensus scientifique.",
      "domain": "philosophy of science"
    },
    {
      "@id": "ko:concept/effondrement",
      "@type": "ko:Concept",
      "prefLabel": "Collapse",
      "altLabel": [
        "effondrement",
        "collapsology collapse"
      ],
      "definition": "Concept li\u00e9 \u00e0 la disparition massive d\u2019esp\u00e8ces, notamment l\u2019humanit\u00e9, en raison du changement climatique.",
      "domain": "ecology"
    },
    {
      "@id": "ko:concept/consensus-scientifique",
      "@type": "ko:Concept",
      "prefLabel": "Scientific Consensus",
      "altLabel": [
        "consensus scientifique"
      ],
      "definition": "Accord d'un nombre suffisamment important de scientifiques sur une connaissance, validant sa validit\u00e9.",
      "domain": "science"
    },
    {
      "@id": "ko:concept/revue-par-les-pairs",
      "@type": "ko:Concept",
      "prefLabel": "Peer Review",
      "altLabel": [
        "revue par les pairs"
      ],
      "definition": "Processus de validation de la rigueur m\u00e9thodologique et des raisonnements scientifiques.",
      "domain": "science"
    },
    {
      "@id": "ko:concept/ecospiritualite",
      "@type": "ko:Concept",
      "prefLabel": "Ecospirituality",
      "altLabel": [
        "\u00e9cospiritualit\u00e9"
      ],
      "definition": "Lien entre la spiritualit\u00e9 et l'\u00e9cologie, souvent associ\u00e9 \u00e0 la collapsologie.",
      "domain": "ecology, spirituality"
    },
    {
      "@id": "ko:concept/effondrement-systemique",
      "@type": "ko:Concept",
      "prefLabel": "Systemic Collapse",
      "altLabel": [
        "effondrement syst\u00e9mique"
      ],
      "definition": "Disparition massive d\u2019esp\u00e8ces et impact durable sur la vie sur Terre, souvent li\u00e9e au changement climatique.",
      "domain": "ecology"
    },
    {
      "@id": "ko:concept/axiomes-collapsologie",
