      "@type": "ko:Concept",
      "prefLabel": "Property-Based Testing",
      "altLabel": [
        "property testing",
        "generative testing"
      ],
      "definition": "A testing technique that generalizes concrete scenarios to focus on essential features, improving bug detection and test robustness.",
      "domain": "software engineering",
      "broader": "ko:concept/software-testing"
