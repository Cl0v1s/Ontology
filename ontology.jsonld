    },
    {
      "@id": "ko:concept/notion-api-limitation",
      "@type": "ko:Concept",
      "prefLabel": "Notion API Limitation",
      "definition": "Constraints of the Notion API that restrict automated bulk operations such as moving or archiving pages programmatically.",
