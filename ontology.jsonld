      "definition": "An AI feature integrated in Notion used to assist with documentation tasks such as summarization and search.",
      "domain": "knowledge management"
    },
    {
      "@id": "ko:concept/documentation-duplication",
      "@type": "ko:Concept",
      "prefLabel": "Documentation Duplication",
      "altLabel": [
