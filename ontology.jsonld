    {
      "@id": "ko:article/apenwarr-every-layer-of-review",
      "@type": "ko:Article",
      "title": "Every layer of review makes you 10x slower",
      "url": "https://apenwarr.ca/log/20260316",
      "publishedDate": "2026-03-16",
      "readDate": "2026-03-18",
      "language": "en",
      "abstract": "Critique des couches d'approbation dans les processus de d\u00e9veloppement logiciel qui ajoutent des d\u00e9lais significatifs sans r\u00e9soudre les causes racines de la latence.",
      "hasAuthor": "ko:author/apenwarr",
      "introduces": [
        "ko:concept/network-effect-laws",
        "ko:concept/coordination-overhead",
        "ko:concept/layers-of-approval",
        "ko:concept/ai-limited-impact",
        "ko:concept/systems-design-challenges",
        "ko:concept/latency-as-bottleneck",
        "ko:concept/ai-developer-descent-into-madness"
      ],
      "critiques": [
        "ko:concept/ai-hype",
        "ko:concept/organizational-design-flaws"
      ]
    },
    {
      "@id": "ko:concept/network-effect-laws",
      "@type": "ko:Concept",
      "prefLabel": "Lois d'effet de r\u00e9seau",
      "altLabel": [
        "network effect laws"
      ],
      "definition": "Les lois selon lesquelles la valeur ou le co\u00fbt de communication dans un r\u00e9seau \u00e9volue avec le nombre de membres (ex: valeur \u221d n\u00b2).",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/coordination-overhead",
      "@type": "ko:Concept",
      "prefLabel": "Surco\u00fbt de coordination",
      "altLabel": [
        "coordination overhead"
      ],
      "definition": "Le temps et les ressources suppl\u00e9mentaires n\u00e9cessaires pour coordonner plusieurs personnes ou \u00e9quipes, qui augmente non-lin\u00e9airement avec la taille du groupe.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/layers-of-approval",
      "@type": "ko:Concept",
      "prefLabel": "Couches d'approbation",
      "altLabel": [
        "layers of review",
        "layers of approval"
      ],
      "definition": "Les multiples niveaux de validation ou d'approbation dans un processus, qui ajoutent des d\u00e9lais exponentiels (chaque couche \u00d710).",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/ai-limited-impact",
      "@type": "ko:Concept",
      "prefLabel": "Impact limit\u00e9 de l'IA",
      "altLabel": [
        "AI's limited impact"
      ],
      "definition": "Le fait que l'IA peut acc\u00e9l\u00e9rer le codage mais ne r\u00e9duit pas les temps d'attente ou les cycles de revue.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/systems-design-challenges",
      "@type": "ko:Concept",
      "prefLabel": "D\u00e9fis de conception syst\u00e8me",
      "altLabel": [
        "systems design challenges"
      ],
      "definition": "Les goulots d'\u00e9tranglement dans les grands projets dus aux cycles de revue et \u00e0 l'absence d'architecture intentionnelle.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/latency-as-bottleneck",
      "@type": "ko:Concept",
      "prefLabel": "Latence comme goulot d'\u00e9tranglement",
      "altLabel": [
        "latency as a bottleneck"
      ],
      "definition": "La majorit\u00e9 du temps dans les processus est pass\u00e9e en attente plut\u00f4t qu'en travail actif.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/ai-developer-descent-into-madness",
      "@type": "ko:Concept",
      "prefLabel": "Descente de l'IA Developer dans la folie",
      "altLabel": [
        "AI developer's descent into madness"
      ],
      "definition": "Le cycle o\u00f9 le code g\u00e9n\u00e9r\u00e9 par IA conduit \u00e0 plus de bugs, n\u00e9cessitant une intervention suppl\u00e9mentaire d'IA.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/ai-hype",
      "@type": "ko:Concept",
      "prefLabel": "Hype sur l'IA",
      "altLabel": [
        "AI hype"
      ],
      "definition": "Les exag\u00e9rations autour des capacit\u00e9s de l'IA, notamment sa capacit\u00e9 \u00e0 r\u00e9soudre les probl\u00e8mes de latence ou de revue.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/organizational-design-flaws",
      "@type": "ko:Concept",
      "prefLabel": "D\u00e9fauts de conception organisationnelle",
      "altLabel": [
        "organizational design flaws"
      ],
      "definition": "L'ajout de couches de revue sans adresser les causes racines des d\u00e9lais dans les organisations.",
      "domain": "software engineering"
    },
    {
