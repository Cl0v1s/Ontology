    {
      "@id": "ko:article/clovis-history-software-simplification",
      "@type": "ko:Article",
      "dc:title": {
        "@language": "en",
        "@value": "The Eternal Promise: A History of Attempts to Eliminate Programmers"
      },
      "dc:description": {
        "@language": "en",
        "@value": "Explores the history of attempts to simplify software creation, from COBOL to AI-driven programming."
      },
      "ko:concept": [
        {
          "@id": "ko:concept/software-simplification",
          "@type": "ko:Concept",
          "skos:prefLabel": [
            {
              "@language": "en",
              "@value": "Software Simplification"
            }
          ],
          "dc:description": {
            "@language": "en",
            "@value": "The historical attempts to simplify software creation, making it accessible to non-programmers."
          }
        },
        {
          "@id": "ko:concept/cobol",
          "@type": "ko:Concept",
          "skos:prefLabel": [
            {
              "@language": "en",
              "@value": "COBOL"
            }
          ],
          "dc:description": {
            "@language": "en",
            "@value": "A programming language designed for business, data processing, and its enduring legacy in critical systems."
          }
        },
        {
          "@id": "ko:concept/ai-hype-cycle",
          "@type": "ko:Concept",
          "skos:prefLabel": [
            {
              "@language": "en",
              "@value": "AI Hype Cycle"
            }
          ],
          "dc:description": {
            "@language": "en",
            "@value": "The recurring pattern of overpromising AI capabilities and the reality gap."
          }
        },
        {
          "@id": "ko:concept/programming-democratization",
          "@type": "ko:Concept",
          "skos:prefLabel": [
            {
              "@language": "en",
              "@value": "Programming Democratization"
            }
          ],
          "dc:description": {
            "@language": "en",
            "@value": "The idea that non-programmers could write software without specialized skills."
          }
