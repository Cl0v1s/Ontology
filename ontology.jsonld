{
  "@context": {
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "dc": "http://purl.org/dc/elements/1.1/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ko": "http://knowledge.local/ontology#"
  },
  "@graph": [

    {
      "@id": "ko:Ontology",
      "@type": "owl:Ontology",
      "rdfs:label": "Knowledge Ontology",
      "rdfs:comment": "Ontologie locale pour la gestion des articles lus et des concepts qu'ils mobilisent.",
      "owl:versionInfo": "1.0"
    },

    {
      "@id": "ko:Article",
      "@type": "owl:Class",
      "rdfs:label": "Article",
      "rdfs:comment": "Un article lu, identifié par un slug. Le script generate-mermaid.mjs affiche les articles comme des nœuds rectangulaires bleus et utilise la propriété 'title' comme libellé."
    },
    {
      "@id": "ko:Concept",
      "@type": "owl:Class",
      "rdfs:label": "Concept",
      "rdfs:comment": "Un concept thématique. Le script generate-mermaid.mjs affiche les concepts comme des ellipses vertes et les regroupe par 'domain'. Utilise 'prefLabel' comme libellé."
    },
    {
      "@id": "ko:Author",
      "@type": "owl:Class",
      "rdfs:label": "Author",
      "rdfs:comment": "L'auteur d'un article. Le script generate-mermaid.mjs affiche les auteurs comme des losanges jaunes et utilise la propriété 'name' comme libellé. IMPORTANT : utiliser @type 'ko:Author' (pas ko:Person ni ko:Organization) et 'name' (pas prefLabel)."
    },

    {
      "@id": "ko:introduces",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "introduces",
      "rdfs:comment": "L'article définit/introduit ce concept (relation centrale). Rendu en bleu gras dans le graphe.",
      "rdfs:domain": { "@id": "ko:Article" },
      "rdfs:range":  { "@id": "ko:Concept" }
    },
    {
      "@id": "ko:uses",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "uses",
      "rdfs:comment": "L'article mobilise ce concept sans le définir. Rendu en gris pointillé.",
      "rdfs:domain": { "@id": "ko:Article" },
      "rdfs:range":  { "@id": "ko:Concept" }
    },
    {
      "@id": "ko:critiques",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "critiques",
      "rdfs:comment": "L'article discute critiquement ce concept. Rendu en rouge.",
      "rdfs:domain": { "@id": "ko:Article" },
      "rdfs:range":  { "@id": "ko:Concept" }
    },
    {
      "@id": "ko:exemplifies",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "exemplifies",
      "rdfs:comment": "L'article illustre ce concept. Rendu en violet pointillé.",
      "rdfs:domain": { "@id": "ko:Article" },
      "rdfs:range":  { "@id": "ko:Concept" }
    },
    {
      "@id": "ko:hasFeature",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "hasFeature",
      "rdfs:comment": "L'article décrit un outil qui possède cette capacité fonctionnelle. Rendu en bleu clair.",
      "rdfs:domain": { "@id": "ko:Article" },
      "rdfs:range":  { "@id": "ko:Concept" }
    },
    {
      "@id": "ko:usesLanguage",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "usesLanguage",
      "rdfs:comment": "L'article décrit un outil implémenté dans ce langage de programmation. Rendu en vert.",
      "rdfs:domain": { "@id": "ko:Article" },
      "rdfs:range":  { "@id": "ko:Concept" }
    },
    {
      "@id": "ko:describes",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "describes",
      "rdfs:comment": "Relation générique article→concept (parent de introduces/uses/critiques/exemplifies). À éviter au profit des sous-propriétés. Rendu en gris dans le graphe.",
      "rdfs:domain": { "@id": "ko:Article" },
      "rdfs:range":  { "@id": "ko:Concept" }
    },
    {
      "@id": "ko:hasAuthor",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "hasAuthor",
      "rdfs:comment": "Relie un article à son auteur (ko:Author). Rendu en gris clair sans pointe de flèche.",
      "rdfs:domain": { "@id": "ko:Article" },
      "rdfs:range":  { "@id": "ko:Author" }
    },
    {
      "@id": "ko:broader",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "broader",
      "rdfs:comment": "Hiérarchie concept→concept : ce concept est plus général. Rendu en marron avec flèche vide.",
      "rdfs:domain": { "@id": "ko:Concept" },
      "rdfs:range":  { "@id": "ko:Concept" }
    },
    {
      "@id": "ko:narrower",
      "@type": "owl:ObjectProperty",
      "rdfs:label": "narrower",
      "rdfs:comment": "Hiérarchie concept→concept : ce concept est plus spécifique. Rendu en marron pointillé avec flèche vide.",
      "rdfs:domain": { "@id": "ko:Concept" },
      "rdfs:range":  { "@id": "ko:Concept" }
    },
  {
       "@id": "ko:related",
       "@type": "owl:ObjectProperty",
       "rdfs:label": "related",
       "rdfs:comment": "Relation symétrique entre concepts. Rendu en violet pointillé sans direction.",
       "rdfs:domain": { "@id": "ko:Concept" },
       "rdfs:range":  { "@id": "ko:Concept" }
     },
    {
      "@id": "ko:Abstraction",
      "@type": "owl:Class",
      "rdfs:label": "Abstraction",
      "rdfs:comment": "Idée qui cache les détails non importants et met en avant les détails pertinents.",
      "skos:broader": { "@id": "ko:Concept" }
    },
    {
      "@id": "ko:Complexity",
      "@type": "owl:Class",
      "rdfs:label": "Complexity",
      "rdfs:comment": "Problème central des codebases mal conçues, souvent trop complexes pour être comprises.",
      "skos:broader": { "@id": "ko:Concept" }
    },
    {
      "@id": "ko:DesignAbstraction",
      "@type": "owl:Class",
      "rdfs:label": "Design Abstraction",
      "rdfs:comment": "Processus de création d'abstractions qui simplifient la compréhension du système.",
      "skos:broader": { "@id": "ko:Concept" }
    },
    {
      "@id": "ko:RedesignAbstraction",
      "@type": "owl:Class",
      "rdfs:label": "Redesign Abstraction",
      "rdfs:comment": "Réévaluation et refonte des abstractions existantes pour les améliorer ou les remplacer.",
      "skos:broader": { "@id": "ko:Concept" }
    },
    {
      "@id": "ko:TechnicalDebt",
      "@type": "owl:Class",
      "rdfs:label": "Technical Debt",
      "rdfs:comment": "Accumulation de problèmes non résolus qui compliquent l'évolution du codebase.",
      "skos:broader": { "@id": "ko:Concept" }
    },
    {
      "@id": "ko:Refactoring",
      "@type": "owl:Class",
      "rdfs:label": "Refactoring",
      "rdfs:comment": "Processus essentiel pour améliorer le code, notamment en redessinant les abstractions.",
      "skos:broader": { "@id": "ko:Concept" }
    },
    {
      "@id": "ko:ComplexityManagement",
      "@type": "owl:Class",
      "rdfs:label": "Complexity Management",
      "rdfs:comment": "Tâche principale des développeurs, consistant à simplifier et structurer les systèmes complexes.",
      "skos:broader": { "@id": "ko:Concept" }
    }
   ]
}
