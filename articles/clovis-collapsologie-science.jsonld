        "ko:concept/effondrement",
        "ko:concept/consensus-scientifique",
        "ko:concept/revue-par-les-pairs",
        "ko:concept/ecospiritualite"
      ],
      "critiques": [
        "ko:concept/collapsologie",
        "ko:concept/science"
      ],
      "describes": [
