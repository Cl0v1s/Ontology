      "@id": "ko:concept/haptic-feedback",
      "@type": "ko:Concept",
      "prefLabel": "Haptic Feedback",
      "definition": "Tactile feedback delivered to a user through vibrations or forces, simulating the sense of touch.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/web-haptics-library",
      "@type": "ko:Concept",
      "prefLabel": "Web Haptics Library",
      "definition": "A JavaScript library that provides haptic feedback capabilities for web applications on mobile devices.",
      "domain": "software engineering"
    },
