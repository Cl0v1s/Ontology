      ],
      "exemplifies": [
        "ko:concept/dnsteal"
      ]
    },
    {
      "@id": "ko:concept/dns-exfiltration",
      "@type": "ko:Concept",
      "prefLabel": "DNS Exfiltration",
      "definition": "Technique to exfiltrate data from a corporate network to an attacker-controlled server using the DNS protocol. Data is encoded (base64 or hex) and transmitted via DNS queries.",
      "domain": "cybersecurity",
      "broader": "ko:concept/data-exfiltration"
    },
    {
      "@id": "ko:concept/dns-tunneling",
      "@type": "ko:Concept",
      "prefLabel": "DNS Tunneling",
      "definition": "Using the DNS protocol as a tunnel to transfer data between two machines. Allows bypassing network restrictions by using the unmonitored port 53.",
      "domain": "cybersecurity",
      "broader": "ko:concept/network-tunneling"
    },
    {
      "@id": "ko:concept/command-and-control-c2",
      "@type": "ko:Concept",
      "prefLabel": "Command and Control (C2)",
      "definition": "Bidirectional communication between infected malware and an attacker-controlled server. Includes data exfiltration and remote commands.",
      "domain": "cybersecurity",
      "broader": "ko:concept/malware-operations"
    },
    {
      "@id": "ko:concept/dnsteal",
      "@type": "ko:Concept",
      "prefLabel": "DNSteal",
      "definition": "Python script implementing the server-side receiver for direct DNS exfiltration (variant A). Listens on port 53, decodes received data and saves it while recreating the original file structure.",
      "domain": "cybersecurity"
    },
    {
