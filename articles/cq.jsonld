  "@graph": [
    {
      "@id": "cq",
      "@type": "ko:Article",
      "prefLabel": "cq",
      "definition": "Article de Clovis Quesada publié sur bdx.town le 25 mars 2026, explorant la notion de 'courage quantique' et ses implications philosophiques.",
      "domain": "philosophy",
      "datePublished": "2026-03-25",
      "author": {"@id": "clovis"}
    },
    {
      "@id": "ko:concept/courage-quantique",
      "@type": "ko:Concept",
      "prefLabel": "Courage quantique",
      "altLabel": ["quantum courage"],
      "definition": "La capacité à agir avec détermination dans l'incertitude, inspirée par les principes de la mécanique quantique où le choix existe avant d'être observé.",
      "domain": "philosophy"
    },
    {
      "@id": "ko:concept/uncertainty-as-freedom",
      "@type": "ko:Concept",
      "prefLabel": "L'incertitude comme liberté",
      "altLabel": ["uncertainty as freedom"],
      "definition": "La perspective selon laquelle l'absence de certitude n'est pas une contrainte mais une opportunité d'exploration et de création.",
      "domain": "philosophy"
    },
    {
      "@id": "ko:concept/observation-effect",
      "@type": "ko:Concept",
      "prefLabel": "Effet d'observation",
      "altLabel": ["observer effect"],
      "definition": "Principe quantique selon lequel l'acte d'observer influence le système observé, appliqué métaphoriquement à la façon dont nos choix façonnent notre réalité.",
      "domain": "physics"
    },
    {
      "@id": "ko:concept/quantum-superposition",
      "@type": "ko:Concept",
      "prefLabel": "Superposition quantique",
      "altLabel": ["quantum superposition"],
      "definition": "État où un système existe simultanément dans plusieurs états possibles jusqu'à ce qu'une mesure soit effectuée.",
      "domain": "physics"
    },
    {
      "@id": "ko:concept/decision-as-creation",
      "@type": "ko:Concept",
      "prefLabel": "La décision comme création",
      "altLabel": ["decision as creation"],
      "definition": "L'idée que chaque choix n'est pas une sélection parmi des options préexistantes, mais l'acte de créer une nouvelle réalité.",
      "domain": "philosophy"
    }
  ]
}
