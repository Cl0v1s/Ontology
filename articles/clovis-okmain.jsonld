      "@id": "ko:concept/colour-clustering",
      "@type": "ko:Concept",
      "prefLabel": "Colour Clustering",
      "definition": "The grouping of similar colors in an image using clustering algorithms to identify dominant colors.",
      "domain": "software engineering"
    },
    {
