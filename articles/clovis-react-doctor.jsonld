  "@graph": [
    {
      "@id": "ko:article/react-doctor",
      "@type": "ko:Article",
      "title": "React Doctor - Diagnostic Tool for React Code",
      "url": "https://github.com/millionco/react-doctor",
      "publishedDate": "2026-03-10",
      "readDate": "2026-03-10",
      "language": "en",
      "abstract": "A tool that diagnoses and fixes React code, providing actionable diagnostics for security, performance, correctness, and architecture issues.",
      "hasAuthor": "ko:author/clovis",
      "introduces": [
        "ko:concept/react-doctor",
        "ko:concept/coding-agent",
        "ko:concept/diagnostic-tool",
        "ko:concept/react-code-analysis",
