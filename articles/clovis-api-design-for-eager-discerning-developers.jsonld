      "@id": "ko:article/api-design-for-eager-discerning-developers",
      "@type": "ko:Article",
      "title": "Eagerly discerning, discerningly eager - API Design for Developers",
      "url": "https://increment.com/apis/api-design-for-eager-discerning-developers/",
      "publishedDate": "2026-03-09",
      "readDate": "2026-03-09",
      "language": "en",
      "abstract": "Discusses the balance between convenience and power in API design, targeting both eager and discerning developers.",
      "introduces": [
        "ko:concept/api-design",
        "ko:concept/eager-developer",
        "ko:concept/discerning-developer",
        "ko:concept/convenience-vs-power",
        "ko:concept/integration-guide",
        "ko:concept/pits-of-success",
