{"@context": {"owl": "http://www.w3.org/2002/07/owl#", "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#", "rdfs": "http://www.w3.org/2000/01/rdf-schema#", "skos": "http://www.w3.org/2004/02/skos/core#", "dc": "http://purl.org/dc/elements/1.1/", "dcterms": "http://purl.org/dc/terms/", "xsd": "http://www.w3.org/2001/XMLSchema#", "ko": "http://knowledge.local/ontology#"}, "@graph": [{"@id": "ko:article/mistral-forge", "@type": "ko:Article", "title": "Forge - Mistral AI", "url": "https://mistral.ai/news/forge", "publishedDate": "2026-03-24", "readDate": "2026-03-24", "language": "en", "abstract": "Forge est un système pour les entreprises de construire des modèles IA frontier-grade basés sur leur connaissance propriétaire, permettant le contrôle stratégique et l'autonomie.", "hasAuthor": "ko:author/mistral-ai", "introduces": ["ko:concept/forge"], "uses": ["ko:concept/institutional-knowledge", "ko:concept/pre-training", "ko:concept/post-training", "ko:concept/reinforcement-learning"]}, {"@id": "ko:author/mistral-ai", "@type": "ko:Organization", "prefLabel": "Mistral AI", "definition": "Entreprise française de développement de modèles d'intelligence artificielle.", "domain": "artificial intelligence"}, {"@id": "ko:concept/forge", "@type": "ko:Concept", "prefLabel": "Forge", "altLabel": ["Mistral Forge"], "definition": "Système pour les entreprises de construire des modèles IA frontier-grade basés sur leur connaissance propriétaire, permettant le contrôle stratégique et l'autonomie.", "domain": "artificial intelligence"}, {"@id": "ko:concept/institutional-knowledge", "@type": "ko:Concept", "prefLabel": "Institutional Knowledge", "altLabel": ["proprietary knowledge", "internal knowledge"], "definition": "Connaissance interne d'une organisation : standards, politiques, codebases, processus opérationnels et décisions institutionnelles.", "domain": "enterprise"}, {"@id": "ko:concept/pre-training", "@type": "ko:Concept", "prefLabel": "Pre-training", "altLabel": ["pretraining"], "definition": "Entraînement initial d'un modèle sur de grands datasets internes pour construire des modèles domain-aware.", "domain": "machine learning"}, {"@id": "ko:concept/post-training", "@type": "ko:Concept", "prefLabel": "Post-training", "altLabel": ["posttraining"], "definition": "Méthodes permettant d'affiner le comportement d'un modèle pour des tâches et environnements spécifiques.", "domain": "machine learning"}, {"@id": "ko:concept/reinforcement-learning", "@type": "ko:Concept", "prefLabel": "Reinforcement Learning", "altLabel": ["RL"], "definition": "Apprentissage par renforcement permettant d'aligner les modèles et agents avec des politiques internes, critères d'évaluation et objectifs opérationnels.", "domain": "machine learning"}, {"@id": "ko:concept/strategic-autonomy", "@type": "ko:Concept", "prefLabel": "Strategic Autonomy", "altLabel": ["strategic autonomy"], "definition": "Capacité d'une organisation à garder le contrôle sur ses modèles, données et propriété intellectuelle en les construisant sur sa propre connaissance.", "domain": "enterprise"}, {"@id": "ko:concept/dense-models", "@type": "ko:Concept", "prefLabel": "Dense Models", "altLabel": ["dense models"], "definition": "Modèles denses fournissant de fortes capacités générales à travers une large gamme de tâches d'entreprise.", "domain": "machine learning"}, {"@id": "ko:concept/mixture-of-experts", "@type": "ko:Concept", "prefLabel": "Mixture of Experts", "altLabel": ["MoE", "mixture-of-experts"], "definition": "Architecture permettant à de très grands modèles de s'exécuter efficacement avec une latence et un coût de calcul inférieurs.", "domain": "machine learning"}, {"@id": "ko:concept/multimodal-inputs", "@type": "ko:Concept", "prefLabel": "Multimodal Inputs", "altLabel": ["multimodal"], "definition": "Support d'entrées multimodales permettant aux modèles d'apprendre à partir de texte, images et autres formats de données.", "domain": "machine learning"}, {"@id": "ko:concept/agent-first-design", "@type": "ko:Concept", "prefLabel": "Agent-first Design", "altLabel": ["agent-first"], "definition": "Approche de conception où les code agents sont les utilisateurs primaires des outils de développement, conçus en premier.", "domain": "software engineering"}, {"@id": "ko:concept/continuous-improvement", "@type": "ko:Concept", "prefLabel": "Continuous Improvement", "altLabel": ["ongoing improvement"], "definition": "Adaptation continue des modèles via des pipelines d'apprentissage par renforcement utilisant le feedback de évaluations internes et workflows opérationnels.", "domain": "machine learning"}, {"@id": "ko:concept/evaluation-frameworks", "@type": "ko:Concept", "prefLabel": "Evaluation Frameworks", "altLabel": ["evaluation frameworks"], "definition": "Cadres permettant aux entreprises de tester les modèles contre des benchmarks internes, règles de conformité et tâches domain-spécifiques.", "domain": "machine learning"}]}
