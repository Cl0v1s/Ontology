        "ko:concept/bloom-effect",
        "ko:concept/barrel-distortion",
        "ko:concept/per-pixel-persistence-trails",
        "ko:concept/chromatic-aberration",
        "ko:concept/grain-texture"
      ],
      "hasFeature": [
