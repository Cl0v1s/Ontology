      "@type": "ko:Concept",
      "prefLabel": "Minimalist Design",
      "altLabel": ["Minimalism"],
      "definition": "A design approach that emphasizes simplicity, clean lines, and the elimination of unnecessary elements to achieve a visually balanced and functional result.",
      "domain": "design"
    },
