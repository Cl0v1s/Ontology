    {
      "@id": "ko:concept/bombadil",
      "@type": "ko:Concept",
      "prefLabel": "Bombadil",
      "definition": "A property-based testing tool for web UIs, autonomously exploring and validating correctness properties.",
      "domain": "software engineering",
      "broader": "ko:concept/property-based-testing"
    },
    {
      "@id": "ko:concept/state-space-exploration",
      "@type": "ko:Concept",
      "prefLabel": "State Space Exploration",
      "definition": "The systematic exploration of all possible states of a system to identify potential bugs or edge cases.",
      "domain": "software engineering",
      "broader": "ko:concept/property-based-testing"
    },
    {
      "@id": "ko:concept/specification-language",
      "@type": "ko:Concept",
      "prefLabel": "Specification Language",
      "definition": "A domain-specific language used to define properties and action generators for testing web applications.",
      "domain": "software engineering",
      "broader": "ko:concept/property-based-testing"
    },
    {
      "@id": "ko:concept/antithesis",
      "@type": "ko:Concept",
      "prefLabel": "Antithesis",
      "definition": "A platform or company associated with Bombadil, providing tools and services for property-based testing.",
      "domain": "software engineering"
