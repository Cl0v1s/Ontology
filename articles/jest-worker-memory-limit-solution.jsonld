    {
      "@id": "ko:concept/max-worker-memory-limit",
      "@type": "ko:Concept",
      "prefLabel": "Max Worker Memory Limit (Jest)",
      "altLabel": [
        "Jest maxWorkerMemoryLimit",
        "worker memory limit in Jest"
      ],
      "definition": "A configuration option in Jest that limits the maximum memory a worker process can use, forcing recycling if the limit is exceeded. This helps mitigate or bypass memory leak issues.",
