{"article": {"@id": "ko:article/gnome-hig", "title": "GNOME Human Interface Guidelines (HIG)", "url": "https://developer.gnome.org/hig/", "readDate": "2026-04-15", "publishedDate": "2023-01-01", "language": "en", "abstract": "The GNOME Human Interface Guidelines (HIG) provide design principles, guidelines, and patterns for creating applications with the GNOME platform.", "introduces": ["ko:concept/gnome-design-principles"], "uses": ["ko:concept/gnome-guidelines", "ko:concept/gnome-patterns-containers", "ko:concept/gnome-patterns-navigation", "ko:concept/gnome-patterns-controls", "ko:concept/gnome-patterns-feedback", "ko:concept/gnome-reference-keyboard-shortcuts"], "hasFeature": ["ko:concept/gnome-guidelines"]}, "newConcepts": [{"@id": "ko:concept/gnome-design-principles", "prefLabel": "GNOME Design Principles", "definition": "Règles de base pour la conception d'applications GNOME, couvrant l'ergonomie et les bonnes pratiques.", "domain": "UI/UX design"}, {"@id": "ko:concept/gnome-guidelines", "prefLabel": "GNOME Guidelines", "definition": "Conventions UX pour le nommage, les icônes, l'interaction et la typographie dans GNOME.", "domain": "UI/UX design"}, {"@id": "ko:concept/gnome-patterns-containers", "prefLabel": "GNOME Patterns - Containers", "definition": "Éléments de conception réutilisables pour les conteneurs, comme les fenêtres, barres d'en-tête et popovers.", "domain": "UI/UX design"}, {"@id": "ko:concept/gnome-patterns-navigation", "prefLabel": "GNOME Patterns - Navigation", "definition": "Éléments de navigation comme les onglets, sidebars et view switchers.", "domain": "UI/UX design"}, {"@id": "ko:concept/gnome-patterns-controls", "prefLabel": "GNOME Patterns - Controls", "definition": "Contrôles d'interface comme les boutons, menus et champs de texte.", "domain": "UI/UX design"}, {"@id": "ko:concept/gnome-patterns-feedback", "prefLabel": "GNOME Patterns - Feedback", "definition": "Mécanismes de feedback comme les notifications, toasts et dialogs.", "domain": "UI/UX design"}, {"@id": "ko:concept/gnome-reference-keyboard-shortcuts", "prefLabel": "GNOME Reference - Keyboard Shortcuts", "definition": "Raccourcis clavier standard pour les applications GNOME.", "domain": "UI/UX design"}]}