    {
      "@id": "ko:concept/comptage-des-pages-et-optimisation-de-la-base-de-données",
      "@type": "ko:Concept",
      "prefLabel": "Page Counting and Database Optimization",
      "altLabel": [
        "page counting",
        "database optimization"
      ],
      "definition": "Avoid expensive queries for counting pages or elements. Use estimated paginators or caches for critical counts.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/requêtes-longues-et-jobs-cron",
      "@type": "ko:Concept",
      "prefLabel": "Long-Running Queries and Cron Jobs",
      "altLabel": [
        "cron jobs",
        "long-running queries"
      ],
      "definition": "Inefficient queries in cron jobs can degrade system performance. Monitor these queries and use read-only databases to isolate them.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/pression-mémoire-ram",
      "@type": "ko:Concept",
      "prefLabel": "Memory Pressure (RAM)",
      "altLabel": [
        "memory pressure",
        "RAM pressure"
      ],
      "definition": "Memory pressure can slow down the system without crashing it, using swap.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/surveillance-des-déploiements",
      "@type": "ko:Concept",
      "prefLabel": "Deployment Monitoring",
      "altLabel": [
        "deployment monitoring",
        "APM monitoring"
      ],
      "definition": "Mark each deployment in an APM (e.g., New Relic) to correlate code changes with performance regressions.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/optimisation-frontend-react",
      "@type": "ko:Concept",
      "prefLabel": "Frontend Optimization (React)",
      "altLabel": [
        "frontend optimization",
        "React optimization"
      ],
      "definition": "Avoid complex DOM elements, unnecessary re-renders, and excessive backend requests. Optimize initial page load for React.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/indexation-et-requêtes-sql",
      "@type": "ko:Concept",
      "prefLabel": "Indexing and SQL Queries",
      "altLabel": [
        "SQL indexing",
        "query optimization"
      ],
      "definition": "Use composite indexes and avoid inefficient queries like `ORDER BY created`. Remove unnecessary data to improve performance.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/compétences-full-stack",
      "@type": "ko:Concept",
      "prefLabel": "Full-Stack Skills",
      "altLabel": [
        "full-stack development",
        "bottleneck reduction"
      ],
      "definition": "Encourage a full-stack approach among developers to reduce bottlenecks.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/éviter-les-blame-games",
      "@type": "ko:Concept",
      "prefLabel": "Avoid Blame Games",
      "altLabel": [
        "blame culture",
        "cumulative failures"
      ],
      "definition": "Production errors are often the result of cumulative failures (code, review, QA, etc.). Avoid assigning blame and focus on solutions.",
      "domain": "team dynamics"
    },
    {
      "@id": "ko:concept/documentation-des-attentes",
      "@type": "ko:Concept",
      "prefLabel": "Documenting Expectations",
      "altLabel": [
        "expectation documentation",
        "behavior guidance"
      ],
      "definition": "Clarify expectations to guide behavior (e.g., resolve issues before they reach management).",
      "domain": "team dynamics"
    },
    {
      "@id": "ko:concept/gestion-des-performances",
      "@type": "ko:Concept",
      "prefLabel": "Performance Management",
      "altLabel": [
        "performance issues",
        "frustration avoidance"
      ],
      "definition": "Address performance issues early with teams to avoid frustration.",
      "domain": "team dynamics"
    },
    {
      "@id": "ko:concept/tech-debt-fridays",
      "@type": "ko:Concept",
      "prefLabel": "Tech Debt Fridays",
      "definition": "A practice of dedicating regular Friday time slots to address technical debt and improve code quality.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/linters-et-prs-courts",
      "@type": "ko:Concept",
      "prefLabel": "Linters et PRs Courts",
      "definition": "L'utilisation de linters automatiques et de pull requests courtes pour maintenir la qualité du code et faciliter les revues.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/communication-dans-les-équipes-à-distance",
      "@type": "ko:Concept",
      "prefLabel": "Communication dans les Équipes à Distance",
      "definition": "Les pratiques et outils permettant une communication efficace au sein d'équipes distribuées géographiquement.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/page-de-demandes-fonctionnelles",
      "@type": "ko:Concept",
      "prefLabel": "Page de Demandes Fonctionnelles",
      "definition": "Un espace centralisé où les parties prenantes peuvent soumettre et suivre les demandes de nouvelles fonctionnalités.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/alertes-et-inbox-zero",
      "@type": "ko:Concept",
      "prefLabel": "Alertes et Inbox Zero",
      "definition": "La pratique de maintenir une boîte de réception vide en traitant immédiatement les alertes système.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/surveillance-des-emails-et-notifications-push",
      "@type": "ko:Concept",
      "prefLabel": "Surveillance des Emails et Notifications Push",
      "definition": "Le monitoring proactif des emails et notifications pour détecter rapidement les problèmes système.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/monitoring-des-files-d-attente",
      "@type": "ko:Concept",
      "prefLabel": "Monitoring des Files d'Attente",
      "definition": "La surveillance continue des files d'attente de messages pour détecter les congestions et anomalies.",
      "domain": "software engineering"
    }
  ]
