      "@id": "ko:article/openai-tiktoken",
      "@type": "ko:Article",
      "title": "tiktoken: A fast BPE tokenizer for use with OpenAI's models",
      "url": "https://github.com/openai/tiktoken",
      "publishedDate": "2025-10-06",
      "readDate": "2026-03-31",
      "language": "en",
      "abstract": "tiktoken is an open-source library that provides a fast Byte Pair Encoding (BPE) tokenizer optimized for OpenAI's models. It supports tokenization for various models, including GPT-4 and GPT-2, and offers performance improvements compared to other open-source tokenizers.",
      "hasAuthor": "ko:author/openai",
