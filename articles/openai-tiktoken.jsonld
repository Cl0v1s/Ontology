      ],
      "usesLanguage": [
        "ko:concept/python"
      ]
    },
    {
      "@id": "ko:concept/bpe-tokenizer",
      "@type": "ko:Concept",
      "prefLabel": "Byte Pair Encoding (BPE) Tokenizer",
      "definition": "A subword tokenization technique used in natural language processing to convert text into tokens for machine learning models.",
      "domain": "natural-language-processing"
    },
    {
      "@id": "ko:concept/tokenization",
      "@type": "ko:Concept",
      "prefLabel": "Tokenizer",
      "definition": "A tool or algorithm that converts text into tokens for use in machine learning models.",
