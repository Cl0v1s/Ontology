  "@graph": [
    {
      "@id": "ko:concept/low-memory-runtime",
      "@type": "ko:Concept",
      "prefLabel": "Runtime à faible empreinte mémoire",
      "altLabel": [
        "low-memory runtime",
        "minimal footprint"
      ],
      "definition": "Environnement d'exécution conçu pour fonctionner avec une quantité extrêmement limitée de RAM et de ROM.",
      "domain": "embedded systems",
      "related": [
        "ko:concept/embedded-systems"
      ]
    },
    {
      "@id": "ko:concept/javascript-embedded",
      "@type": "ko:Concept",
      "prefLabel": "JavaScript embarqué",
      "altLabel": [
        "embedded JavaScript"
      ],
      "definition": "Utilisation du langage JavaScript dans des environnements à ressources contraintes, hors des navigateurs web.",
      "domain": "embedded systems",
      "related": [
        "ko:concept/javascript-engine",
        "ko:concept/embedded-systems"
      ]
    }
  ]
