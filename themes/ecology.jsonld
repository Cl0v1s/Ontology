      "@id": "ko:concept/effondrement",
      "@type": "ko:Concept",
      "prefLabel": "Collapse",
      "altLabel": [
        "effondrement",
        "collapsology collapse"
      ],
      "definition": "Concept lié à la disparition massive d’espèces, notamment l’humanité, en raison du changement climatique.",
      "domain": "ecology"
    },
    {
      "@id": "ko:concept/effondrement-systemique",
      "@type": "ko:Concept",
      "prefLabel": "Systemic Collapse",
      "altLabel": [
        "effondrement systémique"
      ],
      "definition": "Disparition massive d’espèces et impact durable sur la vie sur Terre, souvent liée au changement climatique.",
      "domain": "ecology"
    }
  ]
