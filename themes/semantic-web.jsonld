  "@graph": [
    {
      "@id": "ko:concept/jsonld-transformation",
      "@type": "ko:Concept",
      "prefLabel": "Transformation JSON-LD",
      "definition": "Opérations sur des documents JSON-LD : compactage, expansion, aplatissement, conversion en RDF.",
      "domain": "semantic web"
    },
    {
      "@id": "ko:concept/data-canonization",
      "@type": "ko:Concept",
      "prefLabel": "Canonisation de données",
      "altLabel": [
        "data canonization",
        "RDF dataset normalization"
      ],
      "definition": "Processus produisant une représentation normalisée et déterministe d'un graphe RDF.",
      "domain": "semantic web"
    },
    {
      "@id": "ko:concept/json-ld",
      "@type": "ko:Concept",
      "prefLabel": "JSON-LD",
      "altLabel": [
        "JSON for Linked Data"
      ],
      "definition": "Format de données basé sur JSON pour représenter des données liées selon les principes du web sémantique.",
      "domain": "semantic web"
    }
  ]
}
