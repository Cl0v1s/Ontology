  "@graph": [
    {
      "@id": "ko:concept/simplicite-logicielle",
      "@type": "ko:Concept",
      "prefLabel": "Simplicité logicielle",
      "altLabel": ["simplicity in software", "minimalism"],
      "definition": "La notion que plus un système est simple, moins il consomme d'énergie.",
      "domain": "software engineering",
      "related": ["ko:concept/gouvernance-soutenable"]
    },
    {
      "@id": "ko:concept/gouvernance-soutenable",
      "@type": "ko:Concept",
      "prefLabel": "Gouvernance soutenable",
      "definition": "L'intégration de pratiques durables dans la gouvernance des projets.",
      "domain": "sustainability",
      "related": ["ko:concept/simplicite-logicielle"]
    },
    {
      "@id": "ko:concept/mesure-impact-ecologique",
      "@type": "ko:Concept",
      "prefLabel": "Mesure de l'impact écologique",
      "definition": "Évaluer et mesurer l'impact environnemental des systèmes.",
      "domain": "sustainability",
      "related": ["ko:concept/taux-de-rebond"]
    },
    {
      "@id": "ko:concept/pue",
      "@type": "ko:Concept",
      "prefLabel": "PUE (Indicateur d'efficacité énergétique)",
      "altLabel": ["Power Usage Effectiveness", "energy efficiency metric"],
      "definition": "Mesure de l'efficacité énergétique des centres de données.",
      "domain": "sustainability"
    },
    {
      "@id": "ko:concept/taux-de-rebond",
      "@type": "ko:Concept",
      "prefLabel": "Taux de rebond",
      "altLabel": ["bounce rate", "user engagement metric"],
      "definition": "Un indicateur utilisé pour adapter une page web et réduire son impact énergétique.",
      "domain": "sustainability",
      "related": ["ko:concept/mesure-impact-ecologique"]
    },
    {
      "@id": "ko:concept/collapsologie",
      "@type": "ko:Concept",
      "prefLabel": "Collapsology",
      "altLabel": ["collapsologie", "science de l'effondrement"],
      "definition": "Exercice transdisciplinaire visant à l’étude de l’effondrement de la société thermo-industrielle et de ce qui pourrait lui succéder.",
      "domain": "ecology, sociology"
    },
    {
      "@id": "ko:concept/transdisciplinarite",
      "@type": "ko:Concept",
      "prefLabel": "Transdisciplinarity",
      "altLabel": ["transdisciplinarité"],
      "definition": "Approche qui dépasse les frontières des disciplines spécialisées pour construire de nouvelles connaissances.",
      "domain": "science"
    },
    {
      "@id": "ko:concept/multidisciplinarite",
      "@type": "ko:Concept",
      "prefLabel": "Multidisciplinary Approach",
      "altLabel": ["multidisciplinarité"],
      "definition": "Approche centrée sur plusieurs disciplines sans les intégrer pour construire de nouvelles connaissances.",
      "domain": "science"
    },
    {
      "@id": "ko:concept/science",
      "@type": "ko:Concept",
      "prefLabel": "Science",
      "altLabel": ["science"],
      "definition": "Ensemble de connaissances valides produites par des méthodes rigoureuses, validées par les pairs et soumises au consensus scientifique.",
      "domain": "philosophy of science"
    },
    {
      "@id": "ko:concept/effondrement",
      "@type": "ko:Concept",
      "prefLabel": "Collapse",
      "altLabel": ["effondrement", "collapsology collapse"],
      "definition": "Concept lié à la disparition massive d’espèces, notamment l’humanité, en raison du changement climatique.",
      "domain": "ecology"
    },
    {
      "@id": "ko:concept/consensus-scientifique",
      "@type": "ko:Concept",
      "prefLabel": "Scientific Consensus",
      "altLabel": ["consensus scientifique"],
      "definition": "Accord d'un nombre suffisamment important de scientifiques sur une connaissance, validant sa validité.",
      "domain": "science"
    },
    {
      "@id": "ko:concept/revue-par-les-pairs",
      "@type": "ko:Concept",
      "prefLabel": "Peer Review",
      "altLabel": ["revue par les pairs"],
      "definition": "Processus de validation de la rigueur méthodologique et des raisonnements scientifiques.",
      "domain": "science"
    },
    {
      "@id": "ko:concept/effondrement-systemique",
      "@type": "ko:Concept",
      "prefLabel": "Systemic Collapse",
      "altLabel": ["effondrement systémique"],
      "definition": "Effondrement global des systèmes socio-économiques et écologiques, souvent lié aux crises climatiques.",
      "domain": "ecology"
    },
    {
      "@id": "ko:concept/axiomes-de-la-collapsologie",
      "@type": "ko:Concept",
      "prefLabel": "Axioms of Collapsology",
      "altLabel": ["axiomes de la collapsologie"],
      "definition": "Principe fondamental de la collapsologie, souvent lié à l'effondrement des systèmes complexes.",
      "domain": "ecology"
    },
