      "prefLabel": "Science",
      "altLabel": ["science"],
      "definition": "Ensemble de connaissances valides produites par des méthodes rigoureuses, validées par les pairs et soumises au consensus scientifique.",
      "domain": "philosophy of science"
    },
    {
      "@id": "ko:concept/effondrement",
      "@type": "ko:Concept",
      "prefLabel": "Collapse",
      "altLabel": ["effondrement", "collapsology collapse"],
      "definition": "Concept lié à la disparition massive d’espèces, notamment l’humanité, en raison du changement climatique.",
      "domain": "ecology"
    },
    {
      "@id": "ko:concept/consensus-scientifique",
      "@type": "ko:Concept",
      "prefLabel": "Scientific Consensus",
      "altLabel": ["consensus scientifique"],
      "definition": "Accord d'un nombre suffisamment important de scientifiques sur une connaissance, validant sa validité.",
      "domain": "science"
    },
    {
      "@id": "ko:concept/revue-par-les-pairs",
      "@type": "ko:Concept",
      "prefLabel": "Peer Review",
      "altLabel": ["revue par les pairs"],
      "definition": "Processus de validation de la rigueur méthodologique et des raisonnements scientifiques.",
      "domain": "science"
    },
    {
      "@id": "ko:concept/ecospiritualite",
      "@type": "ko:Concept",
      "prefLabel": "Ecospirituality",
      "altLabel": ["écospiritualité"],
      "definition": "Lien entre la spiritualité et l'écologie, souvent associé à la collapsologie.",
      "domain": "ecology, spirituality"
    },
    {
      "@id": "ko:concept/effondrement-systemique",
      "@type": "ko:Concept",
      "prefLabel": "Systemic Collapse",
      "altLabel": ["effondrement systémique"],
      "definition": "Disparition massive d’espèces et impact durable sur la vie sur Terre, souvent liée au changement climatique.",
      "domain": "ecology"
    },
    {
      "@id": "ko:concept/axiomes-collapsologie",
      "@type": "ko:Concept",
      "prefLabel": "Axioms of Collapsology",
      "altLabel": ["axiomes de la collapsologie"],
      "definition": "Présupposés non prouvés spécifiques à la collapsologie, comme l’inévitabilité de l’effondrement.",
      "domain": "collapsology"
    },
    {
      "@id": "ko:concept/solar-power-system",
      "@type": "ko:Concept",
      "prefLabel": "Solar Power System",
      "altLabel": ["système solaire de puissance"],
      "definition": "Système conçu pour capturer l'énergie solaire et la convertir en électricité utilisable, souvent utilisé pour des applications hors réseau.",
      "domain": "ecology"
    },
    {
      "@id": "ko:concept/low-voltage-dc-systems",
      "@type": "ko:Concept",
      "prefLabel": "Low-Voltage DC Systems",
      "altLabel": ["systèmes basse tension continue"],
      "definition": "Systèmes électriques fonctionnant en courant continu à faible voltage, souvent utilisés dans les applications solaires.",
      "domain": "ecology"
    },
    {
      "@id": "ko:concept/charge-controller",
      "@type": "ko:Concept",
      "prefLabel": "Charge Controller",
      "altLabel": ["régulateur de charge"],
      "definition": "Dispositif qui régule le courant Coming from the solar panels to prevent overcharging or undercharging of batteries.",
      "domain": "ecology"
    },
    {
      "@id": "ko:concept/battery-explosion-prevention",
      "@type": "ko:Concept",
      "prefLabel": "Battery Explosion Prevention",
      "altLabel": ["prévention des explosions de batteries"],
      "definition": "Techniques et mesures pour éviter les risques d'explosion ou de surchauffe des batteries.",
      "domain": "ecology"
    },
    {
      "@id": "ko:concept/solar-panel-installation",
      "@type": "ko:Concept",
      "prefLabel": "Solar Panel Installation",
      "altLabel": ["installation de panneaux solaires"],
      "definition": "Processus d'installation des panneaux solaires pour une production d'énergie optimale.",
      "domain": "ecology"
    },
    {
      "@id": "ko:concept/decentralized-power-production",
      "@type": "ko:Concept",
      "prefLabel": "Decentralized Power Production",
      "altLabel": ["production décentralisée d'énergie"],
      "definition": "Approche de production d'énergie locale, réduisant la dépendance aux réseaux centralisés.",
      "domain": "ecology"
    },
    {
      "@id": "ko:concept/off-grid-solar-setup",
      "@type": "ko:Concept",
      "prefLabel": "Off-Grid Solar Setup",
      "altLabel": ["installation solaire hors réseau"],
      "definition": "Système solaire conçu pour fonctionner indépendamment du réseau électrique public.",
      "domain": "ecology"
    },
    {
      "@id": "ko:concept/english",
      "@type": "ko:Concept",
      "prefLabel": "English",
      "altLabel": ["anglais"],
      "definition": "Langue utilisée dans les documents techniques ou scientifiques.",
      "domain": "ecology"
    }
  ]
