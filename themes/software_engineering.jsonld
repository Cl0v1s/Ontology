{
  "@context": {
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "dc": "http://purl.org/dc/elements/1.1/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ko": "http://knowledge.local/ontology#"
  },
  "@graph": [
    {
      "@id": "ko:concept/software-engineering",
      "@type": "ko:Concept",
      "prefLabel": "Software Engineering",
      "definition": "The broader context of software development, teamwork, and engineering practices.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/glue-work",
      "@type": "ko:Concept",
      "prefLabel": "Glue Work",
      "definition": "The role of essential but less visible tasks in software engineering teams that contribute to team success.",
      "domain": "software engineering",
      "related": ["ko:concept/technical-leadership", "ko:concept/team-success"]
    },
    {
      "@id": "ko:concept/technical-leadership",
      "@type": "ko:Concept",
      "prefLabel": "Technical Leadership",
      "definition": "Demonstrating and building strong technical leadership skills, often through coordination and glue work.",
      "domain": "software engineering",
      "related": ["ko:concept/glue-work"]
    },
    {
      "@id": "ko:concept/career-path",
      "@type": "ko:Concept",
      "prefLabel": "Career Path",
      "definition": "The trajectory chosen by an individual in their professional development.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/team-success",
      "@type": "ko:Concept",
      "prefLabel": "Team Success",
      "definition": "The collective achievement of a team's goals, enabled by visible and invisible contributions.",
      "domain": "software engineering",
      "related": ["ko:concept/glue-work"]
    }
  ]
}
