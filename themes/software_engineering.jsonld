{
  "@context": {
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "dc": "http://purl.org/dc/elements/1.1/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ko": "http://knowledge.local/ontology#"
  },
  "@graph": [
    {
      "@id": "outil",
      "@type": "Concept",
      "label": "Outil",
      "description": "Une entité logicielle ou matérielle servant à manipuler, analyser ou visualiser des données.",
      "subconcepts": ["outilDeTransformation", "outilDeVisualisation", "outilDeValidation"]
    },
    {
      "@id": "outilDeTransformation",
      "@type": "Concept",
      "label": "Outil de Transformation",
      "description": "Un outil permettant de transformer des données (ex: compactage, expansion, canonisation)."
    },
    {
      "@id": "outilDeVisualisation",
      "@type": "Concept",
      "label": "Outil de Visualisation",
      "description": "Un outil permettant de représenter graphiquement des données ou des relations (ex: diagrammes, graphes)."
    },
    {
      "@id": "outilDeValidation",
      "@type": "Concept",
      "label": "Outil de Validation",
      "description": "Un outil permettant de valider la structure ou la cohérence des données (ex: schémas, syntaxe)."
    },
    {
      "@id": "ko:concept/glue-work",
      "@type": "ko:Concept",
      "prefLabel": "Glue Work",
      "definition": "The role of a 'glue' in software engineering teams, involving less glamorous but essential tasks that contribute to team success.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/technical-leadership",
      "@type": "ko:Concept",
      "prefLabel": "Technical Leadership",
      "definition": "Demonstrating and building strong technical leadership skills through glue work.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/career-path",
      "@type": "ko:Concept",
      "prefLabel": "Career Path",
      "definition": "Ensuring that individuals choose a career path they actually want to be on.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/team-success",
      "@type": "ko:Concept",
      "prefLabel": "Team Success",
      "definition": "The importance of glue work in making a team successful.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/software-engineering",
      "@type": "ko:Concept",
      "prefLabel": "Software Engineering",
      "definition": "The broader context of software development and teamwork.",
      "domain": "software engineering"
    },
    {
      "@id": "aFonctionnalite",
      "@type": "Property",
      "label": "a pour fonctionnalité",
      "domain": "outil",
      "range": "Concept"
    },
    {
      "@id": "utiliseLangage",
      "@type": "Property",
      "label": "utilise le langage de programmation",
      "domain": "outil",
      "range": "Concept"
    },
    {
      "@id": "aPourDomaine",
      "@type": "Property",
      "label": "est utilisé dans le domaine",
      "domain": "outil",
      "range": "Concept"
    }
  ]
}
