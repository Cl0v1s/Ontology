      "@id": "ko:concept/multi-computer-control",
      "@type": "ko:Concept",
      "prefLabel": "Contrôle multi-ordinateurs",
      "altLabel": [
        "KVM software",
        "input sharing"
      ],
      "definition": "Partage d'un clavier et d'une souris entre plusieurs ordinateurs via un logiciel.",
      "domain": "productivity"
    },
    {
      "@id": "ko:concept/multi-computer-workflow",
      "@type": "ko:Concept",
      "prefLabel": "Flux de travail multi-ordinateurs",
      "definition": "Organisation du travail impliquant plusieurs machines physiques utilisées simultanément.",
      "domain": "productivity"
    }
  ]
