      ],
      "definition": "Ensemble d'outils utilisés pour développer, compiler et déployer un logiciel.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/software-engineering",
      "@type": "ko:Concept",
      "prefLabel": "Software Engineering",
      "definition": "The broader context of software development, teamwork, and engineering practices.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/glue-work",
      "@type": "ko:Concept",
      "prefLabel": "Glue Work",
      "definition": "The role of essential but less visible tasks in software engineering teams that contribute to team success.",
