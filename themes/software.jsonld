  "@graph": [
    {
      "@id": "ko:concept/outil",
      "@type": "ko:Concept",
      "prefLabel": "Outil",
      "definition": "Un logiciel ou une bibliothèque conçu pour faciliter une tâche spécifique, souvent dans le contexte du développement ou de la productivité.",
      "domain": "software"
    },
    {
      "@id": "ko:concept/outil-de-visualisation",
      "@type": "ko:Concept",
      "prefLabel": "Outil de Visualisation",
      "definition": "Un outil conçu pour représenter des données ou des processus sous une forme visuelle, facilitant l'analyse et la compréhension.",
      "domain": "software"
    }
  ]
}