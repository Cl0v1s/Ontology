{
  "@context": {
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "dc": "http://purl.org/dc/elements/1.1/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ko": "http://knowledge.local/ontology#"
  },
  "@graph": [
    {
      "@id": "ko:concept/vector-mode",
      "@type": "ko:Concept",
      "prefLabel": "Vector Mode",
      "altLabel": [
        "vector display mode"
      ],
      "definition": "Mode d'affichage phosphor CRT avec multi-pass bloom, pistes de persistance par canal, aberration chromatique et grain.",
      "domain": "display technology"
    },
    {
      "@id": "ko:concept/crt-mode",
      "@type": "ko:Concept",
      "prefLabel": "CRT Mode",
      "altLabel": [
        "crt simulation mode"
      ],
      "definition": "Mode de simulation NTSC 256×224 avec lignes de balayage gaussiennes, grille d'aperture Trinitron, halation, température de couleur chaude et interlace flicker.",
      "domain": "display technology"
    },
    {
      "@id": "ko:concept/phosphor-glow",
      "@type": "ko:Concept",
      "prefLabel": "Phosphor Glow",
      "altLabel": [
        "phosphor glow effect"
      ],
      "definition": "Effet de lueur phosphore simulé via des passes de rendu multiples pour imiter les écrans CRT.",
      "domain": "display technology"
    },
    {
      "@id": "ko:concept/scanlines",
      "@type": "ko:Concept",
      "prefLabel": "Scanlines",
      "altLabel": [
        "scanline effect"
      ],
      "definition": "Lignes de balayage simulées avec flou gaussien pour imiter les écrans CRT analogiques.",
      "domain": "display technology"
    },
    {
      "@id": "ko:concept/bloom-effect",
      "@type": "ko:Concept",
      "prefLabel": "Bloom Effect",
      "altLabel": [
        "bloom",
        "glow bloom"
      ],
      "definition": "Effet de flou lumineux multi-pass pour simuler la diffusion de lumière sur les écrans phosphor.",
      "domain": "display technology"
    },
    {
      "@id": "ko:concept/barrel-distortion",
      "@type": "ko:Concept",
      "prefLabel": "Barrel Distortion",
      "altLabel": [
        "barrel distortion effect"
      ],
      "definition": "Distortion en barillet pour simuler les écrans CRT avec lentilles courbées.",
      "domain": "display technology"
    },
    {
      "@id": "ko:concept/per-pixel-persistence-trails",
      "@type": "ko:Concept",
      "prefLabel": "Per-Pixel Persistence Trails",
      "altLabel": [
        "persistence trails"
      ],
      "definition": "Effet de traînées de persistance par pixel pour imiter la décharge progressive des phosphores CRT.",
      "domain": "display technology"
    },
    {
      "@id": "ko:concept/chromatic-aberration",
      "@type": "ko:Concept",
      "prefLabel": "Chromatic Aberration",
      "altLabel": [
        "chromatic aberration effect"
      ],
      "definition": "Décalage chromatique simulé pour imiter les défauts optiques des écrans CRT anciens.",
      "domain": "display technology"
    },
    {
      "@id": "ko:concept/grain-texture",
      "@type": "ko:Concept",
      "prefLabel": "Grain Texture",
      "altLabel": [
        "grain",
        "film grain"
      ],
      "definition": "Texture de grain ajoutée pour simuler le bruit des écrans CRT et l'aspect analogique.",
      "domain": "display technology"
    }
  ]
}
