    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ko": "http://knowledge.local/ontology#"
  },
  "@graph": [
    {
      "@id": "ko:concept/haptic-feedback",
      "@type": "ko:Concept",
      "prefLabel": "Haptic Feedback",
      "definition": "Tactile feedback provided by a device (e.g., smartphone) to enhance user interaction, often used in mobile applications.",
      "domain": "mobile-development"
    },
    {
      "@id": "ko:concept/web-haptics-library",
      "@type": "ko:Concept",
      "prefLabel": "Web Haptics Library",
      "definition": "A library for adding haptic feedback to mobile web applications, supporting frameworks like React, Vue, and Svelte.",
      "domain": "mobile-development"
    },
    {
      "@id": "ko:concept/react",
      "@type": "ko:Concept",
      "prefLabel": "React",
      "definition": "A JavaScript library for building user interfaces, developed by Facebook.",
      "domain": "web-development"
    },
    {
      "@id": "ko:concept/vue",
      "@type": "ko:Concept",
      "prefLabel": "Vue",
      "definition": "A progressive framework for building user interfaces, known for its simplicity and flexibility.",
      "domain": "web-development"
    },
    {
      "@id": "ko:concept/svelte",
      "@type": "ko:Concept",
      "prefLabel": "Svelte",
      "definition": "A radical new way to build user interfaces, focusing on simplicity and performance.",
      "domain": "web-development"
    },
    {
      "@id": "ko:concept/mobile-web-enhancement",
      "@type": "ko:Concept",
      "prefLabel": "Mobile Web Enhancement",
      "definition": "Techniques and tools to enhance the mobile web experience, such as haptic feedback.",
      "domain": "mobile-development"
    },
    {
      "@id": "ko:concept/cross-framework-support",
      "@type": "ko:Concept",
      "prefLabel": "Cross-Framework Support",
      "definition": "Support for multiple frameworks (e.g., React, Vue, Svelte) in a single library or tool.",
      "domain": "web-development"
    }
  ]
}