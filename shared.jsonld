    "ko": "http://knowledge.local/ontology#"
  },
  "@graph": [
    {
      "@id": "ko:concept/technical-specification",
      "@type": "ko:Concept",
      "prefLabel": "Technical Specification",
      "definition": "A formal document that defines the requirements, characteristics, and standards for a product or system.",
      "domain": "engineering"
    },
    {
      "@id": "ko:concept/norme-technique",
      "@type": "ko:Concept",
      "prefLabel": "Norme Technique",
      "definition": "A technical standard or guideline that defines the requirements for a product, process, or system.",
      "domain": "engineering"
    },
    {
      "@id": "ko:concept/standardization",
      "@type": "ko:Concept",
      "prefLabel": "Standardization",
      "definition": "The process of establishing standards for products, processes, or systems to ensure consistency and quality.",
      "domain": "engineering"
    },
    {
      "@id": "ko:concept/quality-control",
      "@type": "ko:Concept",
      "prefLabel": "Quality Control",
      "definition": "The process of ensuring that a product or system meets specified quality standards.",
      "domain": "engineering"
    },
    {
      "@id": "ko:concept/engineering-documentation",
      "@type": "ko:Concept",
      "prefLabel": "Engineering Documentation",
      "definition": "Documentation that describes the design, development, and maintenance of a product or system.",
      "domain": "engineering"
    },
    {
      "@id": "ko:concept/formal-requirements",
      "@type": "ko:Concept",
      "prefLabel": "Formal Requirements",
      "definition": "A set of formal, often written, requirements that define the functionality and constraints of a product or system.",
      "domain": "engineering"
    },
    {
      "@id": "ko:concept/french",
      "@type": "ko:Concept",
      "prefLabel": "French",
      "definition": "The French language, used in this article.",
      "domain": "language"
    }
  ]
}