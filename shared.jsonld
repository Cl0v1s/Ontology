{
  "@context": {
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "dc": "http://purl.org/dc/elements/1.1/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ko": "http://knowledge.local/ontology#"
  },
  "@graph": [
    {
      "@id": "ko:concept/requirement-engineering",
      "@type": "ko:Concept",
      "prefLabel": "Requirement Engineering",
      "definition": "The process of defining, documenting, and maintaining requirements for a product or system.",
      "domain": "engineering"
    },
    {
      "@id": "ko:concept/stakeholder-needs",
      "@type": "ko:Concept",
      "prefLabel": "Stakeholder Needs",
      "definition": "The needs, expectations, or constraints expressed by stakeholders in an engineering project.",
      "domain": "engineering"
    },
    {
      "@id": "ko:concept/analysis-requirements",
      "@type": "ko:Concept",
      "prefLabel": "Analysis of Requirements",
      "definition": "The process of analyzing and refining requirements to ensure they are clear, feasible, and aligned with stakeholder needs.",
      "domain": "engineering"
    },
    {
      "@id": "ko:concept/validation-process",
      "@type": "ko:Concept",
      "prefLabel": "Validation Process",
      "definition": "A systematic process to verify that a product or system meets specified requirements and stakeholder expectations.",
      "domain": "engineering"
    },
    {
      "@id": "ko:concept/engineering-design",
      "@type": "ko:Concept",
      "prefLabel": "Engineering Design",
      "definition": "The process of designing and developing a product or system to meet specified requirements.",
      "domain": "engineering"
    },
    {
      "@id": "ko:concept/formal-specification",
      "@type": "ko:Concept",
      "prefLabel": "Formal Specification",
      "definition": "A formal, often mathematical, description of the requirements or behavior of a product or system.",
      "domain": "engineering"
    },
    {
      "@id": "ko:concept/french",
      "@type": "ko:Concept",
      "prefLabel": "French",
      "definition": "The French language, used in this article.",
      "domain": "language"
    }
  ]
}