  },
  "@graph": [
    {
      "@id": "ko:concept/structured-text-extraction",
      "@type": "ko:Concept",
      "prefLabel": "Structured Text Extraction",
      "definition": "The process of extracting structured information from unstructured text using advanced techniques like LLMs.",
      "domain": "text-processing"
    },
    {
      "@id": "ko:concept/source-grounding",
      "@type": "ko:Concept",
      "prefLabel": "Source Grounding",
      "definition": "Mapping extracted information to its exact location in the source text for traceability and verification.",
      "domain": "text-processing"
    },
    {
      "@id": "ko:concept/python-library",
      "@type": "ko:Concept",
      "prefLabel": "Python Library",
      "definition": "A reusable collection of Python modules and functions designed for a specific purpose, such as text extraction.",
      "domain": "software-development"
    },
    {
      "@id": "ko:concept/llm-integration",
      "@type": "ko:Concept",
      "prefLabel": "LLM Integration",
      "definition": "Integration of Large Language Models (LLMs) into applications or workflows for advanced tasks like text extraction.",
      "domain": "ai"
    },
    {
      "@id": "ko:concept/gemini-models",
      "@type": "ko:Concept",
      "prefLabel": "Gemini Models",
      "definition": "A family of AI models developed by Google, used for tasks like text extraction and generation.",
      "domain": "ai"
    },
    {
      "@id": "ko:concept/long-document-processing",
      "@type": "ko:Concept",
      "prefLabel": "Long Document Processing",
      "definition": "Processing large or long documents efficiently, often using techniques like chunking and parallel processing.",
      "domain": "text-processing"
    },
    {
      "@id": "ko:concept/interactive-visualization",
      "@type": "ko:Concept",
      "prefLabel": "Interactive Visualization",
      "definition": "A method to visualize extracted data interactively, allowing users to explore and review results in context.",
      "domain": "data-visualization"
    }
  ]
}