  },
  "@graph": [

    {
      "@id": "ko:concepts",
      "@type": "skos:ConceptScheme",
      "rdfs:label": "Concepts de la base de connaissances"
    },

    {
      "@id": "ko:author/lethain",
      "@type": "ko:Author",
      "name": "Lethain",
      "affiliation": "Independent Thought Leader"
    },
    {
      "@id": "ko:author/clovis",
      "@type": "ko:Author",
      "name": "Clovis",
      "affiliation": "Engineer and Researcher"
    },
    {
      "@id": "ko:author/noidea-dog",
      "@type": "ko:Author",
      "name": "No Idea Dog",
      "affiliation": "Software Engineering Blog"
    },
    {
      "@id": "ko:author/evan-hahn",
      "@type": "ko:Author",
      "name": "Evan Hahn",
      "affiliation": "Independent Software Developer"
    },

    {
      "@id": "ko:concept/outil",
      "@type": "ko:Concept",
      "prefLabel": "Outil logiciel",
      "altLabel": ["software tool", "outil"],
      "definition": "Une entité logicielle servant à manipuler, analyser, visualiser ou transformer des données.",
      "domain": "software engineering",
      "narrower": [
        "ko:concept/outil-de-transformation",
        "ko:concept/outil-de-visualisation",
        "ko:concept/outil-de-validation"
      ]
    },
    {
      "@id": "ko:concept/outil-de-transformation",
      "@type": "ko:Concept",
      "prefLabel": "Outil de transformation",
      "altLabel": ["transformation tool"],
      "definition": "Outil permettant de transformer des données (ex : compactage, expansion, canonisation, compilation).",
      "domain": "software engineering",
      "broader": "ko:concept/outil"
    },
    {
      "@id": "ko:concept/outil-de-visualisation",
      "@type": "ko:Concept",
      "prefLabel": "Outil de visualisation",
      "altLabel": ["visualization tool"],
      "definition": "Outil permettant de représenter graphiquement des données ou des relations (ex : diagrammes, graphes, interfaces).",
      "domain": "software engineering",
      "broader": "ko:concept/outil"
    },
    {
      "@id": "ko:concept/outil-de-validation",
      "@type": "ko:Concept",
      "prefLabel": "Outil de validation",
      "altLabel": ["validation tool"],
      "definition": "Outil permettant de valider la structure ou la cohérence des données (ex : schémas, syntaxe, tests).",
      "domain": "software engineering",
      "broader": "ko:concept/outil"
    },

    {
      "@id": "ko:concept/language-c",
      "@type": "ko:Concept",
      "prefLabel": "C",
      "definition": "Langage de programmation bas niveau, utilisé pour les systèmes embarqués et les bibliothèques système.",
      "domain": "programming languages"
    },
    {
      "@id": "ko:concept/language-cpp",
      "@type": "ko:Concept",
      "prefLabel": "C++",
      "altLabel": ["C plus plus"],
      "definition": "Extension orientée objet du langage C, utilisée pour les systèmes hautes performances.",
      "domain": "programming languages",
      "broader": "ko:concept/language-c"
    },
    {
      "@id": "ko:concept/language-rust",
      "@type": "ko:Concept",
      "prefLabel": "Rust",
      "definition": "Langage de programmation système axé sur la sécurité mémoire et la concurrence sans garbage collector.",
      "domain": "programming languages"
    },
    {
      "@id": "ko:concept/language-python",
      "@type": "ko:Concept",
      "prefLabel": "Python",
      "definition": "Langage de programmation interprété à typage dynamique, très utilisé en data science et scripting.",
      "domain": "programming languages"
    },

    {
      "@id": "ko:concept/embedded-systems",
      "@type": "ko:Concept",
      "prefLabel": "Systèmes embarqués",
      "altLabel": ["embedded systems", "systèmes contraints"],
      "definition": "Environnements informatiques à ressources limitées (RAM, ROM) intégrés dans des dispositifs matériels.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/data-visualization",
      "@type": "ko:Concept",
      "prefLabel": "Visualisation de données",
      "altLabel": ["data visualization"],
      "definition": "Représentation graphique de données ou de structures pour en faciliter l'exploration et la compréhension.",
      "domain": "software engineering"
    }

  ]
}
