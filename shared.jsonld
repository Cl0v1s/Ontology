    },
    {
      "@id": "ko:concept/french",
      "@type": "ko:Concept",
      "prefLabel": "French",
      "definition": "The French language, used in this article.",
      "domain": "language"
    },
    {
      "@id": "ko:concept/outil",
      "@type": "ko:Concept",
      "prefLabel": "Outil",
      "definition": "Un logiciel ou une bibliothèque conçu pour faciliter une tâche spécifique, souvent dans le contexte du développement ou de la productivité.",
      "domain": "software"
    },
    {
      "@id": "ko:concept/ai-code-generation",
      "@type": "ko:Concept",
      "prefLabel": "Génération de code par IA",
      "altLabel": [
        "AI code generation",
        "vibe coding"
      ],
      "definition": "L'utilisation d'agents IA (Copilot, Cursor, Claude Code) pour générer automatiquement du code fonctionnel.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/software-quality-assurance",
      "@type": "ko:Concept",
      "prefLabel": "Assurance qualité logicielle",
      "altLabel": [
        "software quality assurance"
      ],
      "definition": "Les pratiques visant à garantir la correction et la fiabilité du logiciel, incluant les tests et la vérification formelle.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/mathematical-proofs",
      "@type": "ko:Concept",
      "prefLabel": "Preuves mathématiques",
      "altLabel": [
        "mathematical proofs"
      ],
      "definition": "Démonstrations rigoureuses de la vérité d'une proposition mathématique, formalisées dans des assistants de preuve.",
      "domain": "mathematics"
    },
    {
      "@id": "ko:concept/formal-verification",
      "@type": "ko:Concept",
      "prefLabel": "Vérification formelle",
      "altLabel": [
        "formal verification"
      ],
      "definition": "Méthode mathématique pour prouver qu'un système ou un programme satisfait ses spécifications, utilisant des assistants de preuve et des compilateurs vérificateurs.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/lean-4",
      "@type": "ko:Concept",
      "prefLabel": "Lean 4",
      "altLabel": [
        "Lean",
        "Lean theorem prover"
      ],
      "definition": "Assistant de preuve et langage de programmation fonctionnel développé par Leonardo de Moura, utilisé pour la formalisation mathématique et la vérification formelle.",
      "domain": "programming languages"
    },
    {
      "@id": "ko:concept/mcp-protocol",
      "@type": "ko:Concept",
      "prefLabel": "MCP (Model Context Protocol)",
      "altLabel": [
        "Model Context Protocol"
      ],
      "definition": "Protocole standardisé permettant aux modèles IA d'interagir avec des outils externes comme les compilateurs, bases de données et systèmes de fichiers.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/sparse-mixture-of-experts",
      "@type": "ko:Concept",
      "prefLabel": "Sparse Mixture-of-Experts (MoE)",
      "altLabel": [
        "sparse MoE"
      ],
      "definition": "Architecture de modèle où seuls certains experts (modules) sont activés pour chaque token, permettant une capacité élevée avec un coût d'inférence réduit.",
      "domain": "machine learning"
    },
    {
      "@id": "ko:concept/leanstral",
      "@type": "ko:Concept",
      "prefLabel": "Leanstral",
      "altLabel": [
        "Leanstral-120B-A6B-2603"
      ],
      "definition": "Modèle Mixture-of-Experts spécialisé dans la vérification formelle de code Lean 4, développé par Mistral AI. Architecture : ~119 milliards paramètres totaux, ~6,5 milliards actifs par token (4 sur 128 experts).",
      "domain": "machine learning"
    },
    {
      "@id": "ko:concept/ai-specialized-model",
      "@type": "ko:Concept",
      "prefLabel": "Modèle IA spécialisé",
      "altLabel": [
        "specialized AI model"
      ],
      "definition": "Modèle d'IA entraîné spécifiquement pour une tâche ou domaine particulier, offrant des performances supérieures aux modèles généralistes sur cette tâche.",
      "domain": "machine learning"
    },
    {
      "@id": "ko:concept/open-source",
      "@type": "ko:Concept",
      "prefLabel": "Open source",
      "altLabel": [
        "open source"
      ],
      "definition": "Logiciel dont le code source est accessible et modifiable, généralement sous licence permissive (ex: Apache 2.0, MIT).",
      "domain": "software"
    },
    {
      "@id": "ko:concept/apache-2-license",
      "@type": "ko:Concept",
      "prefLabel": "Licence Apache 2.0",
      "altLabel": [
        "Apache License 2.0"
      ],
      "definition": "Licence open source permissive permettant l'utilisation, la modification et la redistribution du code avec attribution.",
      "domain": "legal"
    },
    {
      "@id": "ko:concept/api-free-tier",
      "@type": "ko:Concept",
      "prefLabel": "API gratuit (tier limité)",
      "altLabel": [
        "free API tier"
      ],
      "definition": "Offre d'accès à une API sans coût pour une période limitée ou avec des quotas restreints, visant à collecter des retours utilisateurs.",
      "domain": "software"
    },
    {
      "@id": "ko:concept/auto-hosting",
      "@type": "ko:Concept",
      "prefLabel": "Auto-hébergement",
      "altLabel": [
        "self-hosting"
      ],
      "definition": "Déploiement et exécution d'un logiciel sur ses propres infrastructures plutôt que via un service cloud managé.",
      "domain": "infrastructure"
    },
    {
      "@id": "ko:concept/gpu-cluster",
      "@type": "ko:Concept",
      "prefLabel": "Cluster GPU",
      "altLabel": [
        "GPU cluster"
      ],
      "definition": "Ensemble de cartes graphiques (A100, H100) interconnectées pour l'entraînement ou l'inférence de modèles d'IA.",
      "domain": "infrastructure"
    },
    {
      "@id": "ko:concept/vllm",
      "@type": "ko:Concept",
      "prefLabel": "vLLM",
      "altLabel": [],
      "definition": "Framework open source pour l'inférence haute performance de modèles d'IA, utilisant la PagedAttention et Flash Attention.",
      "domain": "machine learning"
    },
    {
      "@id": "ko:concept/flash-attention",
      "@type": "ko:Concept",
      "prefLabel": "Flash Attention",
      "altLabel": [],
      "definition": "Algorithme d'optimisation des calculs d'attention dans les transformers, réduisant la mémoire et accélérant l'inférence.",
      "domain": "machine learning"
    },
    {
      "@id": "ko:concept/hugging-face",
      "@type": "ko:Concept",
      "prefLabel": "Hugging Face",
      "altLabel": [],
      "definition": "Plateforme et bibliothèque pour le partage de modèles d'IA, datasets et outils de machine learning.",
      "domain": "machine learning"
    },
    {
      "@id": "ko:concept/defi-smart-contracts",
      "@type": "ko:Concept",
      "prefLabel": "Smart contracts DeFi",
      "altLabel": [
        "DeFi smart contracts"
      ],
      "definition": "Contrats intelligents dans la finance décentralisée, sujets à des bugs coûteux nécessitant une vérification formelle.",
      "domain": "blockchain"
    },
    {
      "@id": "ko:concept/critical-software",
      "@type": "ko:Concept",
      "prefLabel": "Logiciels critiques",
      "altLabel": [
        "critical software"
      ],
      "definition": "Systèmes logiciels dont un défaut peut causer des dommages graves (vies humaines, pertes financières massives).",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/mathlib",
      "@type": "ko:Concept",
      "prefLabel": "Mathlib",
      "altLabel": [
        "Lean Mathlib"
      ],
      "definition": "Bibliothèque Lean 4 formalisant les mathématiques, avec plus de 20 000 contributions et 15 millions de dollars de financements en 2025.",
      "domain": "mathematics"
    },
    {
      "@id": "ko:concept/FLT-project",
      "@type": "ko:Concept",
      "prefLabel": "Projet FLT (Fermat's Last Theorem)",
      "altLabel": [
        "FLT project"
      ],
      "definition": "Projet de formalisation du dernier théorème de Fermat par Imperial College London, dirigé par Kevin Buzzard.",
      "domain": "mathematics"
    },
    {
      "@id": "ko:concept/flteval-benchmark",
      "@type": "ko:Concept",
      "prefLabel": "FLTEval benchmark",
      "altLabel": [],
      "definition": "Nouveau benchmark par Mistral AI pour évaluer la capacité des modèles à produire des preuves formelles dans des environnements réalistes.",
      "domain": "machine learning"
    },
    {
      "@id": "ko:concept/claude-opus-4.6",
      "@type": "ko:Concept",
      "prefLabel": "Claude Opus 4.6",
      "altLabel": [],
      "definition": "Modèle de la famille Claude, leader en qualité brute pour la vérification formelle (score FLTEval : 39,6).",
      "domain": "machine learning"
    },
    {
      "@id": "ko:concept/claude-sonnet-4.6",
      "@type": "ko:Concept",
      "prefLabel": "Claude Sonnet 4.6",
      "altLabel": [],
      "definition": "Modèle de la famille Claude, position milieu (score FLTEval : 23,7).",
      "domain": "machine learning"
    },
    {
      "@id": "ko:concept/claude-haiku-4.5",
      "@type": "ko:Concept",
      "prefLabel": "Claude Haiku 4.5",
      "altLabel": [],
      "definition": "Modèle de la famille Claude, position entrée (score FLTEval : 23,0).",
      "domain": "machine learning"
    },
    {
      "@id": "ko:concept/qwen3.5-397B-A17B",
      "@type": "ko:Concept",
      "prefLabel": "Qwen3.5-397B-A17B",
      "altLabel": [],
      "definition": "Modèle open source avec 397 milliards paramètres totaux et 17 milliards actifs, score FLTEval ~25,4 (pass@4).",
      "domain": "machine learning"
    },
    {
      "@id": "ko:concept/glm5-744B-A40B",
      "@type": "ko:Concept",
      "prefLabel": "GLM5-744B-A40B",
      "altLabel": [],
      "definition": "Modèle open source avec 744 milliards paramètres totaux et 40 milliards actifs, score FLTEval ~16,6.",
      "domain": "machine learning"
    },
    {
      "@id": "ko:concept/kimi-k2.5-1T-A32B",
      "@type": "ko:Concept",
      "prefLabel": "Kimi-K2.5-1T-A32B",
      "altLabel": [],
      "definition": "Modèle open source avec 1 trillion paramètres totaux et 32 milliards actifs, score FLTEval ~20,1.",
      "domain": "machine learning"
    },
    {
      "@id": "ko:concept/trustworthy-vibe-coding",
      "@type": "ko:Concept",
      "prefLabel": "Trustworthy vibe coding",
      "altLabel": [],
      "definition": "Vision où l'humain spécifie ce qu'il veut et la machine prouve formellement la conformité du code généré.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/roccq-to-lean-migration",
      "@type": "ko:Concept",
      "prefLabel": "Migration Rocq vers Lean 4",
      "altLabel": [
        "Coq to Lean migration"
      ],
      "definition": "Traduction de preuves formelles entre les écosystèmes Rocq (Coq) et Lean 4, préservant sémantique et notations.",
      "domain": "mathematics"
    },
    {
      "@id": "ko:concept/alpha-proof",
      "@type": "ko:Concept",
      "prefLabel": "AlphaProof",
      "altLabel": [],
      "definition": "Projet de Google DeepMind utilisant Lean pour la recherche en mathématiques, médaille d'argent aux Olympiades 2024.",
      "domain": "machine learning"
    },
    {
      "@id": "ko:concept/cedar-verification",
      "@type": "ko:Concept",
      "prefLabel": "Vérification Cedar",
      "altLabel": [],
      "definition": "Utilisation de Lean par Amazon pour la vérification formelle du langage Cedar (contrats d'accès).",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/lean-4-zulip-community",
      "@type": "ko:Concept",
      "prefLabel": "Communauté Lean 4 Zulip",
      "altLabel": [],
      "definition": "Communauté de plus de 10 000 membres sur Zulip dédiée à Lean 4 et aux preuves formelles.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/leo-de-moura",
      "@type": "ko:Person",
      "prefLabel": "Leonardo de Moura",
      "definition": "Développeur de Lean 4, ex-Microsoft Research.",
      "domain": "author"
    },
    {
      "@id": "ko:concept/kevin-buzzard",
      "@type": "ko:Person",
      "prefLabel": "Kevin Buzzard",
      "definition": "Professeur à Imperial College London, dirige le projet FLT de formalisation.",
      "domain": "author"
    },
    {
      "@id": "ko:concept/mistral-vibe-cli",
      "@type": "ko:Concept",
      "prefLabel": "Mistral Vibe CLI",
      "altLabel": [],
      "definition": "Ligne de commande Mistral Vibe (v2.5.0) avec la commande /leanstall pour configurer Leanstral.",
      "domain": "software"
    },
    {
      "@id": "ko:concept/labs-leanstral-2603-api",
      "@type": "ko:Concept",
      "prefLabel": "API labs-leanstral-2603",
      "altLabel": [],
      "definition": "Point d'accès API gratuit temporaire pour Leanstral, destiné à collecter des retours utilisateurs.",
      "domain": "software"
    },
    {
      "@id": "ko:concept/leanstral-hugging-face-repo",
      "@type": "ko:Concept",
      "prefLabel": "Leanstral sur Hugging Face",
      "altLabel": [],
      "definition": "Dépôt des poids du modèle Leanstral (mistralai/Leanstral-120B-A6B-2603) sous licence Apache 2.0.",
      "domain": "software"
    },
    {
      "@id": "ko:concept/pass-at-metric",
      "@type": "ko:Concept",
      "prefLabel": "pass@N metric",
      "altLabel": [
        "pass@1",
        "pass@2",
        "pass@4",
        "pass@8",
        "pass@16"
      ],
      "definition": "Métrique d'évaluation où le modèle génère N tentatives et on compte combien de preuves compilent.",
      "domain": "machine learning"
    },
    {
      "@id": "ko:concept/epsrc-funding",
      "@type": "ko:Concept",
      "prefLabel": "EPSRC funding",
      "altLabel": [],
      "definition": "Financement du UK Engineering and Physical Sciences Research Council pour le projet FLT jusqu'en 2029.",
      "domain": "research"
    },
    {
      "@id": "ko:concept/paged-attention",
      "@type": "ko:Concept",
      "prefLabel": "PagedAttention",
      "altLabel": [],
      "definition": "Technique d'optimisation de la mémoire pour les transformers, utilisée par vLLM.",
      "domain": "machine learning"
    },
    {
      "@id": "ko:concept/flash-attention-v2",
      "@type": "ko:Concept",
      "prefLabel": "Flash Attention 2",
      "altLabel": [],
      "definition": "Version améliorée de Flash Attention avec des gains de performance supplémentaires.",
      "domain": "machine learning"
    },
    {
      "@id": "ko:concept/ai-specialized-vs-generalist",
      "@type": "ko:Concept",
      "prefLabel": "Modèle spécialisé vs généraliste",
      "altLabel": [],
      "definition": "Comparaison entre modèles entraînés pour une tâche spécifique (Leanstral) et modèles généralistes (Claude, GPT).",
      "domain": "machine learning"
    },
    {
      "@id": "ko:concept/performance-scaling-law",
      "@type": "ko:Concept",
      "prefLabel": "Loi d'échelle des performances",
      "altLabel": [
        "performance scaling law"
      ],
      "definition": "Phénomène où les gains de performance diminuent au-delà d'un certain point (ex: pass@8 à pass@16).",
      "domain": "machine learning"
    },
    {
      "@id": "ko:concept/cto-strategy",
      "@type": "ko:Concept",
      "prefLabel": "Stratégie CTO",
      "altLabel": [],
      "definition": "Décisions stratégiques pour les responsables techniques concernant l'adoption de nouvelles technologies.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/research-accelerator",
      "@type": "ko:Concept",
      "prefLabel": "Accélérateur de recherche",
      "altLabel": [],
      "definition": "Outil ou méthode qui accélère significativement le processus de recherche scientifique.",
      "domain": "research"
    },
    {
      "@id": "ko:concept/production-readiness",
      "@type": "ko:Concept",
      "prefLabel": "Prêt pour la production",
      "altLabel": [
        "production readiness"
      ],
      "definition": "État où une technologie est suffisamment mature et fiable pour être déployée en environnement de production.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/death-star-thinking",
      "@type": "ko:Concept",
      "prefLabel": "Death Star Thinking",
      "altLabel": [
        "Death Star thinking"
      ],
      "definition": "Approche simpliste qui suppose qu'un problème complexe peut être résolu par une seule solution bien placée, ignorant la complexité systémique.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/complex-systems",
      "@type": "ko:Concept",
      "prefLabel": "Systèmes complexes",
      "altLabel": [
        "complex systems"
      ],
      "definition": "Systèmes composés de nombreux éléments interconnectés dont le comportement global émerge des interactions locales, difficilement prévisible.",
      "domain": "systems theory"
    },
    {
      "@id": "ko:concept/bureaucracy",
      "@type": "ko:Concept",
      "prefLabel": "Bureaucratie",
      "altLabel": [
        "bureaucracy"
      ],
      "definition": "Organisation hiérarchisée avec règles formelles et procédures standardisées, souvent nécessaire pour les systèmes complexes.",
      "domain": "organizational theory"
    },
    {
      "@id": "ko:concept/technology-in-government",
      "@type": "ko:Concept",
      "prefLabel": "Technologie dans le gouvernement",
      "altLabel": [
        "technology in government"
      ],
      "definition": "Utilisation des technologies numériques pour moderniser les services publics et améliorer l'efficacité administrative.",
      "domain": "public policy"
    },
    {
      "@id": "ko:concept/leadership-perspective",
      "@type": "ko:Concept",
      "prefLabel": "Perspective leadership",
      "altLabel": [
        "Leadership Perspective"
      ],
      "definition": "Compréhension des objectifs, contraintes et priorités de la direction dans le processus décisionnel.",
      "domain": "leadership"
    },
    {
      "@id": "ko:concept/product-vs-infrastructure-perspectives",
      "@type": "ko:Concept",
      "prefLabel": "Produit vs Infrastructure Perspectives",
      "altLabel": [
        "Product vs. Infrastructure Perspectives"
      ],
      "definition": "Équilibre entre les besoins de l'équipe produit (fonctionnalités utilisateur) et de l'infrastructure (stabilité, performance).",
      "domain": "engineering strategy"
    },
    {
      "@id": "ko:concept/networking-for-context",
      "@type": "ko:Concept",
      "prefLabel": "Networking for Context",
      "altLabel": [
        "Networking for Context"
      ],
      "definition": "Construction d'un réseau large pour emprunter du contexte et de l'expertise sans la politique organisationnelle.",
      "domain": "leadership"
    },
    {
      "@id": "ko:concept/layers-of-context",
      "@type": "ko:Concept",
      "prefLabel": "Couches de contexte",
      "altLabel": [
        "Layers of Context"
      ],
      "definition": "Différentes perspectives ou dimensions impliquées dans l'évaluation d'un problème (technique, organisationnel, financier, leadership).",
      "domain": "systems thinking"
    },
    {
      "@id": "ko:concept/curiosity-over-conviction",
      "@type": "ko:Concept",
      "prefLabel": "Curiosité avant conviction",
      "altLabel": [
        "Curiosity Over Conviction"
      ],
      "definition": "Approcher les problèmes avec curiosité plutôt que conviction pour mieux comprendre les couches de contexte manquantes.",
      "domain": "leadership"
    },
    {
      "@id": "ko:concept/contextual-awareness",
      "@type": "ko:Concept",
      "prefLabel": "Conscience contextuelle",
      "altLabel": [
        "Contextual Awareness"
      ],
      "definition": "Capacité à percevoir et raisonner à travers plusieurs couches de contexte pour prendre des décisions informées.",
      "domain": "systems thinking"
    },
    {
      "@id": "ko:concept/ai-fine-tuning",
      "@type": "ko:Concept",
      "prefLabel": "AI fine-tuning",
      "altLabel": [
        "fine-tuning"
      ],
      "definition": "Processus d'adaptation d'un modèle pré-entraîné à une tâche ou domaine spécifique avec moins de données et de temps que l'entraînement complet.",
      "domain": "machine learning"
    },
    {
      "@id": "ko:concept/machine-learning",
      "@type": "ko:Concept",
      "prefLabel": "Machine Learning",
      "altLabel": [
        "ML"
      ],
      "definition": "Domaine de l'informatique où les systèmes apprennent à partir de données pour effectuer des tâches sans être explicitement programmés.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/model-training",
      "@type": "ko:Concept",
      "prefLabel": "Model Training",
      "altLabel": [
        "model training"
      ],
      "definition": "Processus d'entraînement d'un modèle d'apprentissage automatique sur des données pour optimiser ses performances.",
      "domain": "machine learning"
    },
    {
      "@id": "ko:concept/llm-optimization",
      "@type": "ko:Concept",
      "prefLabel": "LLM Optimization",
      "altLabel": [
        "LLM optimization"
      ],
      "definition": "Techniques pour améliorer les performances, la vitesse ou l'efficacité des grands modèles de langage.",
      "domain": "machine learning"
    },
