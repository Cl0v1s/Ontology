  "@graph": [
    {
      "@id": "ko:concept/colour-clustering",
      "@type": "ko:Concept",
      "prefLabel": "Colour Clustering",
      "definition": "A technique to group similar colours in an image, often using algorithms like K-means clustering.",
      "domain": "image-processing"
    },
    {
      "@id": "ko:concept/oklab-calculations",
      "@type": "ko:Concept",
      "prefLabel": "Oklab Calculations",
      "definition": "A method for calculating and manipulating colours in the Oklab colour space, which is perceptually uniform.",
      "domain": "image-processing"
    },
    {
      "@id": "ko:concept/k-means-clustering",
      "@type": "ko:Concept",
      "prefLabel": "K-means Clustering",
      "definition": "A popular algorithm for partitioning data into K clusters, often used in colour clustering.",
      "domain": "machine-learning"
    },
    {
      "@id": "ko:concept/rust-implementation",
      "@type": "ko:Concept",
      "prefLabel": "Rust Implementation",
      "definition": "A library or tool implemented in Rust, known for its performance and safety.",
      "domain": "software-development"
    },
    {
      "@id": "ko:concept/python-wrapper",
      "@type": "ko:Concept",
      "prefLabel": "Python Wrapper",
      "definition": "A Python library that provides a high-level interface to a lower-level implementation, such as Rust.",
      "domain": "software-development"
    },
    {
      "@id": "ko:concept/image-color-extraction",
      "@type": "ko:Concept",
      "prefLabel": "Image Color Extraction",
      "definition": "The process of extracting dominant or representative colours from an image.",
      "domain": "image-processing"
    },
    {
      "@id": "ko:concept/perceptual-colour-mixing",
      "@type": "ko:Concept",
      "prefLabel": "Perceptual Colour Mixing",
      "definition": "Mixing colours in a perceptually uniform colour space to achieve smoother and more visually pleasing results.",
      "domain": "image-processing"
    }
  ]
}