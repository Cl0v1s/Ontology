{
  "@context": {
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "dc": "http://purl.org/dc/elements/1.1/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ko": "http://knowledge.local/ontology#"
  },
  "@graph": [
    {
      "@id": "outil",
      "@type": "Concept",
      "label": "Outil",
      "description": "Une entité logicielle ou matérielle servant à manipuler, analyser ou visualiser des données.",
      "subconcepts": ["outilDeTransformation", "outilDeVisualisation", "outilDeValidation"]
    },
    {
      "@id": "outilDeTransformation",
      "@type": "Concept",
      "label": "Outil de Transformation",
      "description": "Un outil permettant de transformer des données (ex: compactage, expansion, canonisation)."
    },
    {
      "@id": "outilDeVisualisation",
      "@type": "Concept",
      "label": "Outil de Visualisation",
      "description": "Un outil permettant de représenter graphiquement des données ou des relations (ex: diagrammes, graphes)."
    },
    {
      "@id": "outilDeValidation",
      "@type": "Concept",
      "label": "Outil de Validation",
      "description": "Un outil permettant de valider la structure ou la cohérence des données (ex: schémas, syntaxe)."
    },
    {
      "@id": "aFonctionnalite",
      "@type": "Property",
      "label": "a pour fonctionnalité",
      "domain": "outil",
      "range": "Concept"
    },
    {
      "@id": "utiliseLangage",
      "@type": "Property",
      "label": "utilise le langage de programmation",
      "domain": "outil",
      "range": "Concept"
    },
    {
      "@id": "aPourDomaine",
      "@type": "Property",
      "label": "est utilisé dans le domaine",
      "domain": "outil",
      "range": "Concept"
    },
    {
      "@id": "ko:concepts",
      "@type": "skos:ConceptScheme",
      "rdfs:label": "Concepts de la base de connaissances"
    },
    {
      "@id": "ko:author/lethain",
      "@type": "ko:Author",
      "name": "Lethain",
      "affiliation": "Independent Thought Leader"
    },
    {
      "@id": "ko:author/clovis",
      "@type": "ko:Author",
      "name": "Clovis",
      "affiliation": "Engineer and Researcher"
    },
    {
      "@id": "ko:author/noidea-dog",
      "@type": "ko:Author",
      "name": "No Idea Dog",
      "affiliation": "Software Engineering Blog"
    },
    {
      "@id": "ko:concept/glue-work",
      "@type": "ko:Concept",
      "prefLabel": "Glue Work",
      "definition": "The role of a 'glue' in software engineering teams, involving less glamorous but essential tasks that contribute to team success.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/technical-leadership",
      "@type": "ko:Concept",
      "prefLabel": "Technical Leadership",
      "definition": "Demonstrating and building strong technical leadership skills through glue work.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/career-path",
      "@type": "ko:Concept",
      "prefLabel": "Career Path",
      "definition": "Ensuring that individuals choose a career path they actually want to be on.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/team-success",
      "@type": "ko:Concept",
      "prefLabel": "Team Success",
      "definition": "The importance of glue work in making a team successful.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/software-engineering",
      "@type": "ko:Concept",
      "prefLabel": "Software Engineering",
      "definition": "The broader context of software development and teamwork.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/layers-of-context",
      "@type": "ko:Concept",
      "prefLabel": "Layers of Context",
      "definition": "The different perspectives or dimensions involved in evaluating a problem, such as technical, organizational, financial, and leadership.",
      "domain": "engineering strategy"
    },
    {
      "@id": "ko:concept/curiosity-over-conviction",
      "@type": "ko:Concept",
      "prefLabel": "Curiosity Over Conviction",
      "definition": "Approach problems with curiosity rather than conviction to better understand missing context layers.",
      "domain": "leadership"
    },
    {
      "@id": "ko:concept/contextual-awareness",
      "@type": "ko:Concept",
      "prefLabel": "Contextual Awareness",
      "definition": "The ability to perceive and reason across multiple context layers to make informed decisions.",
      "domain": "leadership"
    },
    {
      "@id": "ko:concept/leadership-perspective",
      "@type": "ko:Concept",
      "prefLabel": "Leadership Perspective",
      "definition": "Understanding the goals, constraints, and priorities of leadership in decision-making.",
      "domain": "leadership"
    },
    {
      "@id": "ko:concept/product-vs-infrastructure-perspectives",
      "@type": "ko:Concept",
      "prefLabel": "Product vs. Infrastructure Perspectives",
      "definition": "Balancing the needs and viewpoints of product engineering and infrastructure teams.",
      "domain": "engineering strategy"
    },
    {
      "@id": "ko:concept/networking-for-context",
      "@type": "ko:Concept",
      "prefLabel": "Networking for Context",
      "definition": "Building a broad network to borrow hard-won context from others without organizational politics.",
      "domain": "leadership"
    },
    {
      "@id": "ko:concept/eco-conception",
      "@type": "ko:Concept",
      "prefLabel": "Éco-conception",
      "altLabel": ["sustainable design", "green design"],
      "definition": "L'idée de concevoir des systèmes numériques en tenant compte de leur impact environnemental.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/simplicite-logicielle",
      "@type": "ko:Concept",
      "prefLabel": "Simplicité logicielle",
      "altLabel": ["simplicity in software", "minimalism"],
      "definition": "La notion que plus un système est simple, moins il consomme d'énergie.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/gouvernance-soutenable",
      "@type": "ko:Concept",
      "prefLabel": "Gouvernance soutenable",
      "altLabel": ["sustainable governance", "lifecycle sustainability"],
      "definition": "Assurer que le système reste soutenable tout au long de son cycle de vie.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/mesure-impact-ecologique",
      "@type": "ko:Concept",
      "prefLabel": "Mesure de l'impact écologique",
      "altLabel": ["eco-impact measurement", "environmental impact assessment"],
      "definition": "Utilisation d'indices comme l'écoindex pour évaluer l'impact environnemental.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/taux-de-rebond",
      "@type": "ko:Concept",
      "prefLabel": "Taux de rebond",
      "altLabel": ["bounce rate", "user engagement metric"],
      "definition": "Un indicateur utilisé pour adapter une page web et réduire son impact énergétique.",
      "domain": "software engineering"
    },
    {
      "@id": "ko:concept/pue",
      "@type": "ko:Concept",
      "prefLabel": "PUE (Indicateur d'efficacité énergétique)",
      "altLabel": ["Power Usage Effectiveness", "energy efficiency metric"],
      "definition": "Mesure de l'efficacité énergétique des centres de données.",
      "domain": "software engineering"
    }
  ]
}
