    "ko": "http://knowledge.local/ontology#"
  },
  "@graph": [
    {
      "@id": "ko:concept/solar-power-system",
      "@type": "ko:Concept",
      "prefLabel": "Solar Power System",
      "definition": "A system that converts solar energy into electrical energy, typically using photovoltaic panels.",
      "domain": "renewable-energy"
    },
    {
      "@id": "ko:concept/low-voltage-dc-systems",
      "@type": "ko:Concept",
      "prefLabel": "Low-Voltage DC Systems",
      "definition": "Electrical systems that operate on direct current (DC) at low voltage, typically used in off-grid applications.",
      "domain": "renewable-energy"
    },
    {
      "@id": "ko:concept/charge-controller",
      "@type": "ko:Concept",
      "prefLabel": "Charge Controller",
      "definition": "A device that regulates the voltage and current coming from a solar panel to a battery, preventing overcharging.",
      "domain": "renewable-energy"
    },
    {
      "@id": "ko:concept/battery-explosion-prevention",
      "@type": "ko:Concept",
      "prefLabel": "Battery Explosion Prevention",
      "definition": "Measures and practices to prevent battery explosions, such as proper ventilation and avoiding short circuits.",
      "domain": "safety"
    },
    {
      "@id": "ko:concept/solar-panel-installation",
      "@type": "ko:Concept",
      "prefLabel": "Solar Panel Installation",
      "definition": "The process of installing solar panels, including mounting and wiring.",
      "domain": "renewable-energy"
    },
    {
      "@id": "ko:concept/decentralized-power-production",
      "@type": "ko:Concept",
      "prefLabel": "Decentralized Power Production",
      "definition": "The production of electricity in small, distributed systems rather than large centralized plants.",
      "domain": "renewable-energy"
    },
    {
      "@id": "ko:concept/off-grid-solar-setup",
      "@type": "ko:Concept",
      "prefLabel": "Off-Grid Solar Setup",
      "definition": "A solar power system designed to operate independently of the electrical grid.",
      "domain": "renewable-energy"
    },
    {
      "@id": "ko:concept/english",
      "@type": "ko:Concept",
      "prefLabel": "English",
      "definition": "The English language.",
      "domain": "language"
    }
  ]
}