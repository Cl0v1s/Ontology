  "@graph": [
    {
      "@id": "ko:concept/concurrent-engineering",
      "@type": "ko:Concept",
      "prefLabel": "Concurrent Engineering",
      "definition": "A method of developing products where different disciplines work together simultaneously to design and develop a product.",
      "domain": "engineering"
    },
    {
      "@id": "ko:concept/cross-functional-teams",
      "@type": "ko:Concept",
      "prefLabel": "Cross-Functional Teams",
      "definition": "Teams composed of members from different disciplines or departments, working together to achieve a common goal.",
      "domain": "engineering"
    },
    {
      "@id": "ko:concept/parallel-development",
      "@type": "ko:Concept",
      "prefLabel": "Parallel Development",
      "definition": "A development approach where multiple tasks or phases are executed simultaneously to speed up the process.",
      "domain": "engineering"
    },
    {
      "@id": "ko:concept/integration-management",
      "@type": "ko:Concept",
      "prefLabel": "Integration Management",
      "definition": "The process of managing the integration of different components or subsystems into a unified whole.",
      "domain": "engineering"
    },
    {
      "@id": "ko:concept/product-development-process",
      "@type": "ko:Concept",
      "prefLabel": "Product Development Process",
      "definition": "The process of designing, developing, and bringing a product to market, often involving multiple stages and disciplines.",
      "domain": "engineering"
    },
    {
      "@id": "ko:concept/collaborative-design",
      "@type": "ko:Concept",
      "prefLabel": "Collaborative Design",
      "definition": "A design approach where multiple stakeholders, including engineers and designers, collaborate to create a product.",
      "domain": "engineering"
    },
    {
      "@id": "ko:concept/french",
      "@type": "ko:Concept",
      "prefLabel": "French",
      "definition": "The French language, used in this article.",
      "domain": "language"
    },
    {
      "@id": "ko:concept/language-rust",
      "@type": "ko:Concept",
      "prefLabel": "Rust",
      "definition": "A systems programming language known for its performance, memory safety, and concurrency features.",
      "domain": "programming"
    },
    {
      "@id": "ko:concept/outil",
      "@type": "ko:Concept",
      "prefLabel": "Outil",
      "definition": "Un logiciel ou une bibliothèque conçu pour faciliter une tâche spécifique, souvent dans le contexte du développement ou de la productivité.",
      "domain": "software"
    },
    {
      "@id": "ko:concept/language-c",
      "@type": "ko:Concept",
      "prefLabel": "C",
      "definition": "A general-purpose programming language known for its performance and widespread use in system/software development.",
      "domain": "programming"
    },
    {
      "@id": "ko:concept/language-python",
      "@type": "ko:Concept",
      "prefLabel": "Python",
      "definition": "A high-level, interpreted programming language known for its readability and versatility in web development, data analysis, and scripting.",
      "domain": "programming"
    },
    {
      "@id": "ko:concept/outil-de-visualisation",
      "@type": "ko:Concept",
      "prefLabel": "Outil de Visualisation",
      "definition": "Un outil conçu pour représenter des données ou des processus sous une forme visuelle, facilitant l'analyse et la compréhension.",
      "domain": "software"
    },
    {
      "@id": "ko:concept/data-visualization",
      "@type": "ko:Concept",
      "prefLabel": "Data Visualization",
      "definition": "The graphical representation of data to facilitate understanding, analysis, and communication of insights.",
      "domain": "data"
    },
    {
      "@id": "ko:concept/graph-algorithms",
      "@type": "ko:Concept",
      "prefLabel": "Graph Algorithms",
      "altLabel": ["algorithmes de graphes"],
      "definition": "Ensemble de techniques algorithmiques pour analyser, traverser et manipuler des structures de graphes.",
      "domain": "computer science"
    }
  ]
}